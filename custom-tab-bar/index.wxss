.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  padding: 6rpx 14rpx calc(6rpx + env(safe-area-inset-bottom));
  background: rgba(251, 246, 240, 0.98);
  border-top: 1rpx solid rgba(113, 81, 55, 0.1);
  box-shadow: 0 -6rpx 20rpx rgba(67, 39, 21, 0.06);
  backdrop-filter: blur(12rpx);
}

.tab-item {
  flex: 1;
  margin: 0 6rpx;
}

.tab-item-shell {
  min-height: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.tab-icon-wrap {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
}

.tab-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.45;
  transition: opacity 0.2s ease;
}

.tab-text {
  font-size: 18rpx;
  line-height: 1.2;
  color: #8a7d72;
  font-weight: 500;
  transition: color 0.2s ease;
}

.tab-icon-active {
  opacity: 1;
}

.tab-text-active {
  color: #8f4324;
  font-weight: 700;
}

.tab-item-indicator {
  width: 6rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #8f4324;
  box-shadow: 0 0 0 4rpx rgba(143, 67, 36, 0.12);
}
