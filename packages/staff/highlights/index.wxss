.staff-highlights-hero {
  padding: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 228, 186, 0.22), transparent 34%),
    linear-gradient(135deg, #4a332c, #6f5043 58%, #d0a06d);
  color: var(--cream-primary);
  border: 1rpx solid rgba(141, 98, 60, 0.14);
}

.staff-highlights-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.staff-highlights-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.staff-highlights-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.staff-highlights-tip-card {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at top right, var(--red-dim), transparent 30%),
    linear-gradient(180deg, #fff8f2, #f2e3d0);
  border: 1rpx solid rgba(141, 98, 60, 0.08);
  border-left: 3rpx solid var(--red-primary);
}

.staff-highlights-tip-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #7b4a31;
}

.staff-highlights-tip-text {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.75;
  color: var(--text-secondary);
}

.highlight-pack {
  margin-top: 18rpx;
  padding: 24rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.highlight-pack-head {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 14rpx;
  min-width: 0;
}

.highlight-pack-title {
  width: 100%;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-all;
}

.highlight-pack-status {
  max-width: 100%;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.35;
  box-sizing: border-box;
}

.status-ok {
  background: rgba(62, 207, 142, 0.1);
  color: var(--status-open);
}

.status-pending {
  background: rgba(245, 158, 11, 0.1);
  color: var(--status-pending);
}

.highlight-pack-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.highlight-pack-actions {
  margin-top: 18rpx;
  display: flex;
  width: 100%;
  min-width: 0;
}

.highlight-upload-btn {
  display: flex;
  flex: 1 1 auto;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  text-align: center;
  white-space: normal;
  line-height: 1.45;
  word-break: break-all;
  overflow-wrap: anywhere;
}

.highlight-media-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.highlight-media-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 249, 242, 0.96);
  border: 1rpx solid rgba(141, 98, 60, 0.08);
}

.highlight-media-visual {
  width: 92rpx;
  height: 92rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background:
    radial-gradient(circle at top right, var(--red-dim), transparent 30%),
    linear-gradient(135deg, #8d5f34, #d1a45d);
}

.highlight-media-image {
  width: 100%;
  height: 100%;
}

.highlight-media-video {
  display: flex;
  align-items: center;
  justify-content: center;
}

.highlight-media-video-icon {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--text-primary);
}

.highlight-media-copy {
  flex: 1;
  min-width: 0;
}

.highlight-media-title {
  font-size: 26rpx;
  font-weight: 600;
}

.highlight-media-tag {
  margin-top: 8rpx;
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  color: var(--red-deep);
  border: 1rpx solid var(--border-red);
  font-size: 20rpx;
}

.highlight-media-remove {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 92, 106, 0.1);
  color: var(--status-danger);
  font-size: 22rpx;
}

.highlight-empty {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 249, 242, 0.96);
  color: var(--text-muted);
  border: 1rpx solid rgba(141, 98, 60, 0.08);
  font-size: 24rpx;
  line-height: 1.7;
}

.highlight-dialog-actions {
  margin-top: 26rpx;
}

.highlight-dialog-actions .button-primary,
.highlight-dialog-actions .button-secondary {
  min-width: 0;
  white-space: normal;
  line-height: 1.45;
}
