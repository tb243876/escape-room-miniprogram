<view class="screen">
  <view class="hero-card staff-revenue-hero">
    <view class="staff-revenue-kicker">门店工作台</view>
    <view class="staff-revenue-title">运营数据</view>
    <view class="staff-revenue-subtitle">展示历史结算场次、主题热度和月度趋势，仅管理权限可见。</view>
  </view>

  <view wx:if="{{isLoading}}" class="card status-card">
    <view class="status-title">数据加载中</view>
    <view class="status-text">请稍候...</view>
  </view>

  <view wx:elif="{{errorText}}" class="card status-card">
    <view class="status-title">数据加载失败</view>
    <view class="status-text">{{errorText}}</view>
    <view class="button-primary status-action" bindtap="retryLoad">重新加载</view>
  </view>

  <block wx:elif="{{analytics}}">
    <view class="section-title">
      <text>整体数据</text>
    </view>
    <view class="staff-revenue-summary">
      <view class="card staff-revenue-card" wx:for="{{analytics.summaryCards}}" wx:key="label">
        <view class="staff-revenue-value">{{item.value}}</view>
        <view class="staff-revenue-label">{{item.label}}</view>
      </view>
    </view>

    <view class="section-title">
      <text>主题场次分布</text>
    </view>
    <view wx:if="{{analytics.themeBreakdown.length}}" class="card staff-revenue-theme-card">
      <view
        class="staff-revenue-theme-row"
        wx:for="{{analytics.visibleThemeBreakdown}}"
        wx:key="theme"
      >
        <view class="staff-revenue-theme-name">{{item.theme}}</view>
        <view class="staff-revenue-theme-meta">{{item.sessionCount}} 场 · 共 {{item.totalPlayers}} 人 · 均 {{item.avgTeamSize}} 人/场</view>
      </view>
      <view
        wx:if="{{analytics.hiddenThemeCount > 0 || sectionState.showAllThemes}}"
        class="staff-revenue-more"
        data-key="showAllThemes"
        bindtap="toggleSection"
      >
        {{sectionState.showAllThemes ? '收起主题分布' : '展开其余 ' + analytics.hiddenThemeCount + ' 个主题'}}
      </view>
    </view>
    <view wx:else class="card status-card">
      <view class="status-title">暂无主题数据</view>
      <view class="status-text">完成场次结算后会自动统计</view>
    </view>

    <view class="section-title">
      <text>近6个月趋势</text>
    </view>
    <view wx:if="{{analytics.monthlyTrend.length}}" class="card staff-revenue-trend-card">
      <view
        class="staff-revenue-trend-row"
        wx:for="{{analytics.visibleMonthlyTrend}}"
        wx:key="month"
      >
        <view class="staff-revenue-trend-month">{{item.month}}</view>
        <view class="staff-revenue-trend-count">{{item.sessionCount}} 场</view>
        <view class="staff-revenue-trend-players">{{item.playerCount}} 人次</view>
      </view>
      <view
        wx:if="{{analytics.hiddenTrendCount > 0 || sectionState.showAllTrends}}"
        class="staff-revenue-more"
        data-key="showAllTrends"
        bindtap="toggleSection"
      >
        {{sectionState.showAllTrends ? '收起月度趋势' : '展开其余 ' + analytics.hiddenTrendCount + ' 个月'}}
      </view>
    </view>
    <view wx:else class="card status-card">
      <view class="status-title">暂无月度数据</view>
      <view class="status-text">完成场次结算后会自动统计</view>
    </view>
  </block>
</view>
