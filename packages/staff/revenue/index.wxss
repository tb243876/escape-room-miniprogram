.staff-revenue-hero {
  padding: 32rpx 32rpx 24rpx;
  background:
    linear-gradient(160deg, rgba(92, 67, 49, 0.08), rgba(92, 67, 49, 0)),
    radial-gradient(circle at top right, rgba(255, 228, 188, 0.2), transparent 34%),
    linear-gradient(135deg, #5b3b30, #7c5a4b 58%, #c8956a);
  color: var(--cream-primary);
}
.staff-revenue-kicker {
  font-size: 22rpx;
  color: rgba(255, 244, 233, 0.78);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}
.staff-revenue-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--cream-primary);
  line-height: 1.2;
  margin-bottom: 8rpx;
}
.staff-revenue-subtitle {
  font-size: 26rpx;
  color: var(--cream-muted);
  line-height: 1.5;
}
.staff-revenue-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 24rpx 8rpx;
}
.staff-revenue-card {
  flex: 1 1 calc(50% - 8rpx);
  min-width: 0;
  padding: 20rpx;
  text-align: center;
  background:
    radial-gradient(circle at top right, rgba(255, 228, 188, 0.16), transparent 32%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
  border: 1rpx solid rgba(141, 98, 60, 0.08);
}
.staff-revenue-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.1;
}
.staff-revenue-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}
.staff-revenue-theme-card {
  padding: 8rpx 20rpx 16rpx;
}
.staff-revenue-theme-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}
.staff-revenue-theme-row:last-child {
  border-bottom: none;
}
.staff-revenue-theme-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.staff-revenue-theme-meta {
  font-size: 21rpx;
  color: var(--text-secondary);
}
.staff-revenue-trend-card {
  padding: 8rpx 20rpx 16rpx;
}
.staff-revenue-trend-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
  gap: 16rpx;
}
.staff-revenue-trend-row:last-child {
  border-bottom: none;
}
.staff-revenue-trend-month {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  width: 108rpx;
  flex-shrink: 0;
}
.staff-revenue-trend-count {
  font-size: 23rpx;
  color: var(--red-primary);
  font-weight: 500;
  flex: 1;
}
.staff-revenue-trend-players {
  font-size: 21rpx;
  color: var(--text-secondary);
}

.staff-revenue-more {
  min-height: 64rpx;
  margin-top: 10rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(158, 61, 34, 0.08);
  border: 1rpx dashed rgba(141, 98, 60, 0.16);
  font-size: 22rpx;
  font-weight: 700;
  color: #7b4a31;
}
