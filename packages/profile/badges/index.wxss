.screen-inner {
  min-height: 100%;
}

.badges-hero {
  padding: 30rpx;
  background:
    linear-gradient(160deg, rgba(255, 232, 202, 0.14), rgba(255, 232, 202, 0)),
    radial-gradient(circle at top right, rgba(255, 228, 186, 0.22), transparent 28%),
    linear-gradient(135deg, #4a332c, #6f5043 58%, #d0a06d);
  color: var(--cream-primary);
}

.badges-kicker {
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: var(--cream-muted);
}

.badges-title {
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.badges-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--cream-muted);
}

.badge-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.profile-badge {
  border-radius: 24rpx;
  padding: 6rpx;
}

.profile-badge-unlocked {
  background: linear-gradient(180deg, rgba(173, 117, 72, 0.96) 0%, rgba(116, 75, 46, 0.96) 100%);
  box-shadow: 0 14rpx 30rpx rgba(94, 62, 39, 0.16);
}

.profile-badge-locked {
  background: linear-gradient(180deg, rgba(214, 203, 191, 0.96) 0%, rgba(184, 168, 151, 0.96) 100%);
}

.profile-badge-inner {
  position: relative;
  min-height: 100%;
  padding: 18rpx 16rpx 20rpx;
  border-radius: 20rpx;
  text-align: center;
  background: rgba(255, 251, 246, 0.34);
  border: 1rpx solid var(--border-subtle);
}

.profile-badge-status {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  background: rgba(245, 240, 235, 0.08);
  color: var(--cream-muted);
}

.profile-badge-icon {
  width: 92rpx;
  height: 92rpx;
  margin: 24rpx auto 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-badge-icon-unlocked {
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
  color: var(--cream-primary);
  box-shadow: 0 12rpx 24rpx rgba(158, 61, 34, 0.18);
}

.profile-badge-icon-locked {
  background: linear-gradient(135deg, #b6a28d, #8f7a67);
  color: #fff8f0;
}

.profile-badge-name {
  margin-top: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.profile-badge-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}
