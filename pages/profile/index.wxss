.profile-page {
  overflow: hidden;
}

.profile-scroll {
  height: calc(100vh - 96rpx - env(safe-area-inset-bottom) - 48rpx);
  box-sizing: border-box;
}

.profile-card {
  padding: 22rpx 22rpx 18rpx;
  background:
    radial-gradient(circle at top right, var(--red-dim), transparent 28%),
    linear-gradient(135deg, rgba(255, 252, 247, 0.98), rgba(245, 236, 226, 0.98));
  box-shadow: 0 12rpx 22rpx rgba(94, 62, 39, 0.1);
}

.profile-head {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.profile-avatar-column {
  width: 94rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
  color: var(--cream-primary);
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 20rpx rgba(94, 62, 39, 0.14);
}

.avatar-image {
  display: block;
}

.profile-level-chip {
  width: 100%;
  min-height: 40rpx;
  padding: 8rpx 10rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 220, 176, 0.24), transparent 34%),
    linear-gradient(135deg, rgba(123, 74, 49, 0.96), rgba(199, 140, 89, 0.96));
  color: #fff6ec;
  font-size: 17rpx;
  line-height: 1.35;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
  box-shadow: 0 10rpx 20rpx rgba(94, 62, 39, 0.12);
}

.profile-name {
  font-size: 30rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 280rpx;
}

.profile-edit-link {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: var(--bg-card-alt);
  color: var(--text-secondary);
  border: 1rpx solid var(--border-default);
  font-size: 20rpx;
  font-weight: 700;
}

.profile-title-row {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.profile-title-badge {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  max-width: 100%;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  border: 1rpx solid var(--border-red);
  color: var(--red-deep);
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1.2;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-signature {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.profile-progress-inline {
  margin-top: 12rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid var(--border-subtle);
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.profile-film-strip {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.profile-film-frame {
  flex: 1 1 180rpx;
  min-width: 180rpx;
  padding: 16rpx 14rpx;
  border-radius: 16rpx;
  background: #634437;
  box-shadow: inset 0 0 0 1rpx var(--border-default);
  color: var(--text-primary);
  position: relative;
  overflow: hidden;
}

.profile-film-frame::before,
.profile-film-frame::after {
  content: '';
  position: absolute;
  top: 10rpx;
  bottom: 10rpx;
  width: 10rpx;
  background: radial-gradient(circle, rgba(245, 240, 235, 0.42) 0 36%, transparent 38% 100%);
  background-size: 10rpx 24rpx;
}

.profile-film-frame::before {
  left: 8rpx;
}

.profile-film-frame::after {
  right: 8rpx;
}

.profile-film-label {
  position: relative;
  z-index: 1;
  padding: 0 16rpx;
  font-size: 19rpx;
  color: var(--text-secondary);
}

.profile-film-value {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.profile-inline-meta {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.profile-meta-pill-action {
  position: relative;
  padding-right: 28rpx;
}

.profile-meta-pill-action::after {
  content: '';
  position: absolute;
  right: 12rpx;
  top: 50%;
  width: 10rpx;
  height: 10rpx;
  margin-top: -6rpx;
  border-top: 2rpx solid var(--border-default);
  border-right: 2rpx solid var(--border-default);
  transform: rotate(45deg);
}

.profile-share-btn {
  margin: 14rpx 0 0;
  width: fit-content;
  min-width: 0;
  padding: 0 22rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  background: var(--red-primary);
  color: var(--cream-primary);
  font-size: 20rpx;
  font-weight: 700;
}

.profile-share-btn::after {
  border: none;
}

.profile-stat-stack {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex-shrink: 0;
}

.profile-stat-compact {
  padding: 12rpx 12rpx 10rpx;
  border-radius: 16rpx;
  background: var(--bg-card-alt);
  border: 1rpx solid var(--border-subtle);
  text-align: center;
}

.profile-stat-compact-action {
  position: relative;
}

.profile-stat-compact-action::after {
  content: '';
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid var(--border-default);
  border-right: 2rpx solid var(--border-default);
  transform: rotate(45deg);
}

.profile-reputation-hero {
  padding: 20rpx 18rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 214, 170, 0.24), transparent 32%),
    linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(245, 234, 221, 0.98));
  border: 1rpx solid rgba(183, 81, 63, 0.14);
  text-align: center;
}

.profile-reputation-score {
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--red-deep);
}

.profile-reputation-tier {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.profile-reputation-hero-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.profile-reputation-hero-row .profile-reputation-tier {
  margin-top: 0;
}

.profile-reputation-recovery-pill {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(158, 61, 34, 0.1);
  font-size: 20rpx;
  font-weight: 700;
  color: var(--red-deep);
}

.profile-reputation-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.profile-reputation-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.profile-growth-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-reputation-item {
  min-width: 0;
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid var(--border-subtle);
}

.profile-reputation-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.profile-reputation-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.profile-reputation-value {
  flex-shrink: 0;
  font-size: 22rpx;
  text-align: right;
  color: var(--red-deep);
}

.profile-reputation-note {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.profile-growth-hero,
.profile-level-hero {
  padding: 20rpx 18rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 214, 170, 0.24), transparent 32%),
    linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(245, 234, 221, 0.98));
  border: 1rpx solid rgba(183, 81, 63, 0.14);
  text-align: center;
}

.profile-growth-score,
.profile-level-name {
  font-size: 46rpx;
  line-height: 1.1;
  font-weight: 700;
  color: var(--red-deep);
}

.profile-growth-tier,
.profile-level-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.profile-growth-progress {
  margin-top: 18rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(108, 71, 47, 0.12);
  overflow: hidden;
}

.profile-growth-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--red-deep), #d9a35e);
}

.profile-growth-hint {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.profile-level-benefit-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.profile-level-benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid var(--border-subtle);
}

.profile-level-benefit-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--red-deep), #d9a35e);
  flex-shrink: 0;
}

.profile-level-benefit-copy {
  flex: 1;
  min-width: 0;
}

.profile-level-benefit-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.profile-level-benefit-note {
  margin-top: 10rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.profile-stat-num {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--red-deep);
}

.profile-stat-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
}

.recent-panel,
.contact-panel {
  margin-top: 20rpx;
  padding: 24rpx;
}

.challenge-panel,
.wish-panel {
  margin-top: 20rpx;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, var(--red-dim), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.challenge-subtitle {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.challenge-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.challenge-card {
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 252, 247, 0.88);
  border: 1rpx solid var(--border-subtle);
}

.challenge-card-done {
  background:
    radial-gradient(circle at top right, var(--red-dim), transparent 28%),
    rgba(255, 245, 231, 0.92);
  border-color: var(--border-red);
}

.challenge-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.challenge-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.challenge-status {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  color: var(--red-deep);
  font-size: 20rpx;
}

.challenge-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.challenge-progress-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.challenge-progress-bar {
  flex: 1;
  height: 12rpx;
  border-radius: 999rpx;
  background: var(--bg-card-alt);
  overflow: hidden;
}

.challenge-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--red-deep), var(--red-primary));
}

.challenge-progress-text {
  flex-shrink: 0;
  font-size: 20rpx;
  color: var(--text-secondary);
}

.wish-card {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 252, 247, 0.9);
  border: 1rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wish-copy {
  flex: 1;
  min-width: 0;
}

.wish-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.wish-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.wish-remove {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(239, 68, 68, 0.1);
  color: var(--status-danger);
  font-size: 22rpx;
}

.recent-panel-archive {
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.18), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.contact-btn {
  min-width: 132rpx;
  padding: 12rpx 18rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.panel-title {
  font-size: 31rpx;
  font-weight: 700;
}

.list-line {
  margin-top: 14rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.tools-panel {
  margin-top: 22rpx;
  padding: 20rpx 20rpx 12rpx;
  background:
    linear-gradient(160deg, rgba(64, 38, 31, 0.03), rgba(64, 38, 31, 0)),
    linear-gradient(135deg, rgba(249, 244, 238, 0.96), rgba(239, 231, 222, 0.96));
  border-style: dashed;
}

.tools-panel-workbench {
  background:
    linear-gradient(160deg, rgba(64, 38, 31, 0.04), rgba(64, 38, 31, 0)),
    radial-gradient(circle at top right, rgba(255, 230, 188, 0.2), transparent 28%),
    linear-gradient(135deg, rgba(249, 244, 238, 0.96), rgba(239, 231, 222, 0.96));
}

.contact-panel-service {
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.18), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.tools-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.tools-subtitle {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.tool-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx 26rpx;
}

.tool-item {
  width: 112rpx;
  min-height: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
  box-sizing: border-box;
}

.tool-item-count-badge {
  position: absolute;
  top: -10rpx;
  right: -8rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #c75d3e, var(--red-primary));
  color: var(--cream-primary);
  font-size: 18rpx;
  font-weight: 700;
  box-sizing: border-box;
  box-shadow: 0 8rpx 14rpx rgba(94, 62, 39, 0.16);
}

.tool-item-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--cream-primary);
  box-shadow:
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.24),
    0 14rpx 24rpx rgba(94, 62, 39, 0.14);
}

.tool-item-icon-badge {
  background: linear-gradient(145deg, #8d5f34, #d1a45d);
}

.tool-item-icon-pending {
  position: relative;
  background: linear-gradient(145deg, #a65135, #d38a52);
}

.tool-item-icon-my-review {
  position: relative;
  background: linear-gradient(145deg, #8f4f33, #c07a4f);
}

.tool-item-icon-perks {
  background: linear-gradient(145deg, #b66d39, #e1b36e);
}

.tool-item-icon-workbench {
  background: linear-gradient(145deg, #7f5c43, #c29871);
}

.tool-item-icon-ranking {
  background: linear-gradient(145deg, #9d6233, #d7a55d);
}

.tool-item-icon-profile {
  background: linear-gradient(145deg, #8d5f34, #d1a45d);
}

.tool-item-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
  text-align: center;
  letter-spacing: 1rpx;
}

.recent-panel {
  background: linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
  border-left: 8rpx solid var(--red-primary);
}

.recent-theme-chip {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 245, 231, 0.9);
  border-left: 6rpx solid var(--red-primary);
  color: var(--text-primary);
  font-size: 24rpx;
}

.contact-panel {
  background:
    radial-gradient(circle at top right, rgba(255, 228, 186, 0.28), transparent 28%),
    linear-gradient(135deg, #fff2e2 0%, #f2dcc2 100%);
  box-shadow: 0 12rpx 22rpx rgba(120, 80, 45, 0.08);
  margin-bottom: 16rpx;
}

.contact-layout {
  display: flex;
  align-items: stretch;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 24rpx;
}

.contact-copy {
  flex: 1;
  min-width: 0;
}

.contact-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--red-primary);
}

.contact-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.contact-btn {
  width: auto;
  align-self: flex-start;
}

.overlay-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: var(--bg-overlay);
}

.overlay-sheet {
  width: 100%;
  height: 78vh;
  padding: 28rpx 24rpx 34rpx;
  border-radius: 30rpx 30rpx 0 0;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 250, 244, 0.98), rgba(246, 239, 230, 0.98));
}

.overlay-sheet-perks {
  background: linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(243, 234, 221, 0.98));
}

.overlay-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.overlay-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--text-secondary);
}

.overlay-title {
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.overlay-close {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--bg-card-alt);
  color: var(--text-primary);
  font-size: 22rpx;
}

.overlay-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.overlay-scroll {
  height: 0;
  flex: 1;
  margin-top: 20rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.overlay-badge-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.overlay-badge-item {
  padding: 18rpx 10rpx 16rpx;
  border-radius: 22rpx;
  text-align: center;
}

.overlay-badge-item-on {
  background: linear-gradient(180deg, rgba(255, 241, 207, 0.98), rgba(241, 216, 156, 0.98));
}

.overlay-badge-item-off {
  background: linear-gradient(180deg, rgba(237, 232, 226, 0.98), rgba(222, 214, 205, 0.98));
}

.overlay-badge-icon {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 245, 231, 0.9);
  color: var(--red-deep);
  font-size: 26rpx;
  font-weight: 700;
}

.overlay-badge-name {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.overlay-perk-line {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.overlay-perk-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
}

.overlay-perk-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.overlay-empty {
  margin-top: 4rpx;
  font-size: 25rpx;
  color: var(--text-muted);
}

.badge-detail-mask {
  position: fixed;
  inset: 0;
  z-index: 1300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  background: rgba(56, 36, 24, 0.5);
}

.badge-detail-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 560rpx;
  padding: 42rpx 32rpx 34rpx;
  border-radius: 30rpx;
  text-align: center;
  background:
    radial-gradient(circle at top, rgba(255, 228, 179, 0.44), transparent 34%),
    linear-gradient(180deg, #fff7ef 0%, #f2e1cc 100%);
  box-shadow: 0 26rpx 80rpx rgba(66, 38, 22, 0.24);
}

.badge-detail-kicker {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--red-deep);
}

.badge-detail-medal {
  width: 184rpx;
  height: 184rpx;
  margin: 24rpx auto 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-detail-medal-on {
  background: radial-gradient(circle at 35% 30%, #fff1c9, #efc26f 55%, #b66a2a 100%);
}

.badge-detail-medal-off {
  background: radial-gradient(circle at 35% 30%, #ede2d2, #b8a38d 58%, #8c735f 100%);
}

.badge-detail-medal-inner {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 250, 242, 0.72);
  color: #7d532f;
  font-size: 46rpx;
  font-weight: 700;
}

.badge-detail-name {
  margin-top: 24rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.badge-detail-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.profile-stats-dialog {
  width: 100%;
  max-height: calc(100vh - 160rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.profile-stats-dialog-compact {
  max-width: 580rpx;
  max-height: calc(100vh - 260rpx);
}

.profile-stats-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.profile-stats-head-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profile-stats-inline-action {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  min-height: 44rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.92);
  border: 1rpx solid var(--border-subtle);
  font-size: 18rpx;
  font-weight: 700;
  color: var(--red-deep);
}

.profile-stats-inline-badge {
  min-width: 26rpx;
  height: 26rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #c75d3e, var(--red-primary));
  color: var(--cream-primary);
  font-size: 14rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.profile-stats-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--text-secondary);
}

.profile-stats-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.profile-stats-close {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--bg-card-alt);
  color: var(--text-secondary);
  font-size: 22rpx;
}

.profile-stats-subtitle {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.profile-stats-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
}

.profile-stats-badge-grid,
.profile-stats-record-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 8rpx;
}

.profile-stats-badge-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.profile-stats-badge-item,
.profile-stats-record-item {
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 252, 247, 0.84);
  border: 1rpx solid var(--border-subtle);
}

.profile-stats-badge-item {
  padding: 16rpx 10rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 10rpx;
  text-align: center;
}

.profile-stats-badge-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #8d5f34, #d1a45d);
  color: var(--cream-primary);
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.profile-stats-badge-name,
.profile-stats-record-theme {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.profile-stats-badge-name {
  width: 100%;
  font-size: 20rpx;
  line-height: 1.4;
  text-align: center;
  word-break: break-all;
}

.profile-stats-badge-desc,
.profile-stats-record-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.profile-pending-review-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid var(--border-subtle);
}

.profile-pending-review-cover-wrap {
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.profile-pending-review-cover,
.profile-pending-review-cover-text {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
  display: block;
  background: linear-gradient(135deg, rgba(123, 74, 49, 0.96), rgba(199, 140, 89, 0.96));
}

.profile-pending-review-cover-text {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--cream-primary);
  font-size: 28rpx;
  font-weight: 700;
}

.profile-pending-review-copy {
  min-width: 0;
  flex: 1;
}

.profile-pending-review-theme {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.profile-pending-review-meta,
.profile-pending-review-session {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.profile-pending-review-btn {
  min-width: 116rpx;
  padding: 14rpx 18rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.profile-my-review-item {
  align-items: flex-start;
}

.profile-my-review-content {
  margin-top: 6rpx;
  font-size: 19rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.profile-my-review-delete {
  min-width: 96rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(178, 65, 43, 0.08);
  border: 1rpx solid rgba(178, 65, 43, 0.18);
  color: #b2412b;
  font-size: 20rpx;
  line-height: 1.2;
  text-align: center;
  flex-shrink: 0;
}

.profile-review-delete-card {
  width: 560rpx;
  max-width: calc(100vw - 72rpx);
}

.profile-review-delete-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.profile-review-delete-btn {
  min-width: 170rpx;
}

.profile-review-delete-btn-danger {
  background: linear-gradient(135deg, #b2412b, #8f2e1a);
  color: #fffaf4;
}

.badge-detail-btn {
  width: auto;
  min-width: 188rpx;
  margin: 24rpx auto 0;
  padding: 14rpx 30rpx;
  font-size: 22rpx;
}

.contact-panel-clear {
  margin-top: 20rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(245, 241, 237, 0.98), rgba(240, 236, 231, 0.98));
  border: 1rpx dashed var(--border-red);
  border-radius: 16rpx;
}

.contact-panel-clear .panel-title {
  font-size: 27rpx;
  color: var(--text-secondary);
}

.contact-panel-clear .contact-text {
  font-size: 24rpx;
  color: var(--text-muted);
}
