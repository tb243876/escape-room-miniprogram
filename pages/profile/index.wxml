<view class="screen screen-with-tabbar profile-page">
  <block wx:if="{{errorText}}">
    <view class="card status-card">
      <view class="status-title">个人主页加载失败</view>
      <view class="status-text">{{errorText}}</view>
      <view class="button-primary status-action" bindtap="retryLoad">重新加载</view>
    </view>
  </block>

  <block wx:elif="{{profile}}">
    <scroll-view class="profile-scroll" scroll-y="true" enhanced="true" show-scrollbar="true">
      <view class="hero-card profile-card">
        <view class="profile-head">
          <block wx:if="{{profile.avatarUrl}}">
            <image class="avatar avatar-image" src="{{profile.avatarUrl}}" mode="aspectFill"></image>
          </block>
          <view wx:else class="avatar">{{profile.avatarText}}</view>
          <view class="profile-copy">
            <view class="profile-head-row">
              <view class="profile-name">{{profile.nickname}}</view>
              <view class="profile-edit-link" bindtap="openProfileEdit">编辑资料</view>
            </view>
            <view class="profile-title-badge">{{profile.titleLabel}}</view>
            <view class="profile-signature">{{profile.signature}}</view>
            <view class="profile-inline-meta">
              <view class="profile-meta-pill pill-soft">{{profile.genderText}}</view>
              <view class="profile-meta-pill pill-soft">成长值 {{profile.growthValue}}</view>
            </view>
          </view>
          <view class="profile-stat-stack">
            <view class="profile-stat-compact">
              <view class="profile-stat-num">{{profile.totalPlayCount}}</view>
              <view class="profile-stat-label">场次</view>
            </view>
            <view class="profile-stat-compact">
              <view class="profile-stat-num">{{profile.badgeCount}}</view>
              <view class="profile-stat-label">徽章</view>
            </view>
          </view>
        </view>
        <view class="profile-honor-list">
          <view class="profile-honor-tag pill-soft" wx:for="{{profile.honorLabels}}" wx:for-item="honor" wx:for-index="index" wx:if="{{index < 2}}" wx:key="*this">{{honor}}</view>
        </view>
        <view class="profile-progress-inline">成长进度：{{profile.nextLevelHint}}</view>
      </view>

      <view class="panel recent-panel recent-panel-archive">
        <view class="panel-title">最近体验主题</view>
        <block wx:if="{{profile.recentThemes.length}}">
          <view class="recent-theme-chip" wx:for="{{profile.recentThemes}}" wx:key="*this">{{item}}</view>
        </block>
        <view wx:else class="list-line">还没有体验记录，等完成第一场真实场次后会自动沉淀到这里。</view>
      </view>

      <view class="panel tools-panel tools-panel-workbench">
        <view class="tools-head">
          <view class="panel-title">常用入口</view>
          <view class="tools-subtitle">这里放你最常用的功能</view>
        </view>
        <view class="tool-list">
          <view class="tool-item tool-item-badge" bindtap="goBadges">
            <view class="tool-item-icon tool-item-icon-badge">徽</view>
            <view class="tool-item-title">徽章</view>
          </view>
          <view class="tool-item tool-item-perks" bindtap="showPerks">
            <view class="tool-item-icon tool-item-icon-perks">券</view>
            <view class="tool-item-title">权益</view>
          </view>
          <view class="tool-item tool-item-workbench" bindtap="openWorkbench">
            <view class="tool-item-icon tool-item-icon-workbench">台</view>
            <view class="tool-item-title">工作台</view>
          </view>
          <view class="tool-item tool-item-ranking" bindtap="openLeaderboard">
            <view class="tool-item-icon tool-item-icon-ranking">榜</view>
            <view class="tool-item-title">排行榜</view>
          </view>
          <view class="tool-item tool-item-profile" bindtap="openProfileEdit">
            <view class="tool-item-icon tool-item-icon-profile">我</view>
            <view class="tool-item-title">个人资料</view>
          </view>
        </view>
      </view>

      <view class="panel contact-panel contact-panel-service">
        <view class="contact-layout">
          <view class="contact-copy">
            <view class="panel-title">联系门店</view>
            <view class="contact-text">有新主题、活动或集锦需求时，可以直接联系门店。</view>
          </view>
          <view class="button-primary contact-btn" bindtap="contactStore">联系门店</view>
        </view>
      </view>
    </scroll-view>
  </block>

  <block wx:else>
    <view class="card status-card">
      <view class="status-title">暂无个人数据</view>
      <view class="status-text">当前还没有可展示的资料，请稍后重试。</view>
    </view>
  </block>

  <view wx:if="{{showBadgesPanel}}" class="overlay-mask" bindtap="closePanels" catchtouchmove="noop">
    <view class="overlay-sheet" catchtap="noop" catchtouchmove="noop">
      <view class="overlay-head">
        <view>
          <view class="overlay-kicker">我的徽章</view>
          <view class="overlay-title">全部徽章</view>
        </view>
        <view class="overlay-close" bindtap="closePanels">关闭</view>
      </view>
      <view class="overlay-subtitle">亮起的是已获得徽章，灰色的是还没拿到的徽章。</view>
      <scroll-view class="overlay-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <view wx:if="{{profile.badgeCatalog.length}}" class="overlay-badge-grid">
          <view class="overlay-badge-item {{item.overlayItemClass}}" wx:for="{{profile.badgeCatalog}}" wx:key="key" bindtap="openBadgeDetail" data-key="{{item.key}}">
            <view class="overlay-badge-icon">{{item.overlayIconText}}</view>
            <view class="overlay-badge-name">{{item.name}}</view>
          </view>
        </view>
        <view wx:else class="overlay-empty">当前还没有徽章数据。</view>
      </scroll-view>

      <view wx:if="{{selectedBadge}}" class="badge-detail-mask" bindtap="closeBadgeDetail">
        <view class="badge-detail-card" catchtap="noop">
          <view class="badge-detail-kicker">{{selectedBadge.detailKicker}}</view>
          <view class="badge-detail-medal {{selectedBadge.detailMedalClass}}">
            <view class="badge-detail-medal-inner">{{selectedBadge.detailMedalText}}</view>
          </view>
          <view class="badge-detail-name">{{selectedBadge.name}}</view>
          <view class="badge-detail-desc">{{selectedBadge.description}}</view>
          <view class="button-primary badge-detail-btn" bindtap="closeBadgeDetail">关闭</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showPerksPanel}}" class="overlay-mask" bindtap="closePanels" catchtouchmove="noop">
    <view class="overlay-sheet overlay-sheet-perks" catchtap="noop" catchtouchmove="noop">
      <view class="overlay-head">
        <view>
          <view class="overlay-kicker">我的权益</view>
          <view class="overlay-title">权益内容</view>
        </view>
        <view class="overlay-close" bindtap="closePanels">关闭</view>
      </view>
      <view class="overlay-subtitle">先把第一版已有权益放进来，后面再扩成可领取、可核销和有效期状态。</view>
      <scroll-view class="overlay-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <view wx:if="{{profile.perks.length}}">
          <view class="overlay-perk-line" wx:for="{{profile.perks}}" wx:key="*this">
            <view class="overlay-perk-dot"></view>
            <view class="overlay-perk-text">{{item}}</view>
          </view>
        </view>
        <view wx:else class="overlay-empty">当前还没有权益内容。</view>
      </scroll-view>
    </view>
  </view>
</view>
