.themes-hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 30rpx 30rpx;
  background:
    repeating-linear-gradient(
      90deg,
      rgba(245, 240, 235, 0.04) 0,
      rgba(245, 240, 235, 0.04) 14rpx,
      rgba(245, 240, 235, 0) 14rpx,
      rgba(245, 240, 235, 0) 28rpx
    ),
    linear-gradient(160deg, rgba(255, 232, 202, 0.14), rgba(255, 232, 202, 0)),
    radial-gradient(circle at top right, rgba(255, 228, 186, 0.22), transparent 34%),
    linear-gradient(135deg, #4a332c, #6f5043 58%, #d0a06d);
  color: var(--cream-primary);
  border: 1rpx solid var(--border-red);
}

.themes-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.themes-stamp {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border-red);
  background: rgba(255, 251, 246, 0.34);
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--cream-muted);
  transform: rotate(-8deg);
}

.themes-title {
  margin-top: 18rpx;
  max-width: 560rpx;
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
}

.themes-subtitle {
  margin-top: 14rpx;
  max-width: 620rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: var(--cream-muted);
}

.search-box {
  padding: 18rpx;
  margin-top: 18rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.2), transparent 32%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.search-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.search-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.search-record {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: var(--bg-card-alt);
  border: 1rpx solid var(--border-default);
  color: var(--text-primary);
}

.search-btn {
  min-width: 120rpx;
}

.tag-scroll {
  white-space: nowrap;
  margin: 20rpx 0 10rpx;
}

.tag-row {
  display: inline-flex;
}

.filter-tag {
  margin-right: 14rpx;
}

.tag-active {
  background: var(--red-primary);
  color: var(--cream-primary);
}

.theme-card {
  overflow: hidden;
  margin-bottom: 18rpx;
  background:
    linear-gradient(90deg, rgba(212, 167, 107, 0.14) 0, rgba(212, 167, 107, 0.14) 16rpx, transparent 16rpx),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(243, 232, 220, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.theme-cover {
  height: 220rpx;
  width: 100%;
  display: block;
}

.theme-content {
  padding: 24rpx;
}

.theme-kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--text-secondary);
}

.theme-name {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.theme-stars {
  margin-top: 10rpx;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.theme-stars-label {
  color: var(--text-secondary);
}

.theme-star {
  display: inline-block;
  margin-right: 2rpx;
  font-size: 26rpx;
  line-height: 1;
}

.theme-star-active {
  color: var(--red-primary);
  font-size: 26rpx;
  line-height: 1;
  text-shadow: 0 2rpx 6rpx rgba(190, 139, 81, 0.22);
}

.theme-star-inactive {
  color: var(--text-muted);
  font-size: 26rpx;
  line-height: 1;
  opacity: 0.95;
}

.theme-slogan,
.theme-meta {
  margin-top: 10rpx;
  font-size: 25rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.tag-wrap {
  margin-top: 12rpx;
}
