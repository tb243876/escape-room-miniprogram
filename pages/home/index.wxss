.home-stage {
  position: relative;
  margin-top: 4rpx;
}

.home-stage-card {
  position: relative;
  overflow: hidden;
  padding: 38rpx 32rpx 32rpx;
  border-radius: 30rpx;
  background:
    repeating-linear-gradient(
      90deg,
      rgba(255, 247, 233, 0.04) 0,
      rgba(255, 247, 233, 0.04) 12rpx,
      rgba(255, 247, 233, 0) 12rpx,
      rgba(255, 247, 233, 0) 24rpx
    ),
    radial-gradient(circle at top right, rgba(238, 206, 154, 0.22), transparent 28%),
    radial-gradient(circle at bottom left, rgba(126, 58, 37, 0.2), transparent 32%),
    linear-gradient(135deg, #261611, #4e2f26 52%, #9d6d46);
  box-shadow: 0 18rpx 40rpx rgba(58, 30, 18, 0.16);
  color: #fff5eb;
  border: 1rpx solid rgba(255, 236, 208, 0.08);
}

.home-stage-card::after {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -56rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 233, 200, 0.18), transparent 64%);
}

.home-stage-kicker {
  position: relative;
  z-index: 1;
  width: fit-content;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 245, 235, 0.12);
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.home-stage-stamp {
  position: absolute;
  right: 26rpx;
  top: 24rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 230, 198, 0.22);
  background: rgba(34, 20, 15, 0.22);
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 245, 235, 0.88);
  transform: rotate(-7deg);
}

.home-stage-title {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  max-width: 560rpx;
  font-size: 48rpx;
  line-height: 1.22;
  font-weight: 700;
}

.home-stage-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  max-width: 620rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: rgba(255, 245, 235, 0.84);
}

.home-stage-meta {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.home-stage-meta-item {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 245, 235, 0.1);
  border: 1rpx solid rgba(255, 245, 235, 0.12);
  font-size: 22rpx;
  color: rgba(255, 245, 235, 0.95);
}

.home-search-shell {
  margin-top: 16rpx;
}

.home-search-kicker {
  margin: 0 2rpx 12rpx;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #8d684d;
}

.home-search-card {
  padding: 18rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 234, 204, 0.22), transparent 32%),
    linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(244, 235, 224, 0.98));
  box-shadow: 0 10rpx 22rpx rgba(85, 56, 33, 0.06);
  border: 1rpx solid rgba(128, 90, 60, 0.08);
}

.home-search-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.home-search-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #5c4030;
}

.home-search-record {
  font-size: 20rpx;
  color: #8d684d;
}

.home-search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.home-search-input {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #f8f1e6;
  font-size: 26rpx;
  border: 1rpx solid rgba(135, 96, 64, 0.08);
}

.home-search-clear {
  flex-shrink: 0;
  padding: 0 18rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: rgba(157, 96, 58, 0.1);
  color: #966244;
  font-size: 22rpx;
  font-weight: 700;
}

.level-block {
  margin-bottom: 18rpx;
}

.level-block {
  padding: 20rpx 18rpx 8rpx;
  border-radius: 26rpx;
  border: 1rpx solid rgba(128, 90, 60, 0.07);
}

.level-block-light {
  background:
    radial-gradient(circle at top right, rgba(255, 237, 211, 0.22), transparent 30%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(248, 239, 228, 0.98));
}

.level-block-medium {
  background:
    radial-gradient(circle at top right, rgba(234, 221, 205, 0.2), transparent 30%),
    linear-gradient(180deg, rgba(249, 243, 236, 0.98), rgba(239, 230, 220, 0.98));
}

.level-block-heavy {
  background:
    radial-gradient(circle at top right, rgba(218, 195, 182, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(243, 236, 231, 0.98), rgba(231, 221, 213, 0.98));
}

.compact-theme-card {
  display: flex;
  align-items: center;
  overflow: hidden;
  margin-bottom: 16rpx;
  background:
    linear-gradient(90deg, rgba(111, 77, 55, 0.06) 0, rgba(111, 77, 55, 0.06) 16rpx, transparent 16rpx),
    rgba(255, 251, 247, 0.82);
  border: 1rpx solid rgba(128, 90, 60, 0.08);
}

.compact-cover {
  width: 190rpx;
  height: 190rpx;
  flex-shrink: 0;
  display: block;
}

.compact-body {
  padding: 24rpx;
}

.compact-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #9d775b;
}

.compact-name {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.horror-stars {
  margin-top: 10rpx;
  font-size: 23rpx;
  letter-spacing: 2rpx;
}

.horror-stars-label {
  color: #8f664c;
}

.horror-star {
  display: inline-block;
  margin-right: 2rpx;
  font-size: 25rpx;
  line-height: 1;
}

.horror-star-active {
  color: #b85d37;
  font-size: 25rpx;
  line-height: 1;
  text-shadow: 0 2rpx 6rpx rgba(184, 93, 55, 0.16);
}

.horror-star-inactive {
  color: #d7c4b6;
  font-size: 25rpx;
  line-height: 1;
  opacity: 0.95;
}

.compact-desc {
  margin-top: 12rpx;
  color: #6d6055;
  font-size: 24rpx;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.compact-meta {
  margin-top: 12rpx;
  color: #7a6b5f;
  font-size: 24rpx;
  line-height: 1.7;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-empty {
  padding: 28rpx 24rpx;
  color: #6d6055;
  font-size: 26rpx;
  border: 1rpx dashed rgba(145, 109, 80, 0.18);
  background: rgba(255, 249, 242, 0.9);
}

.level-title-row {
  margin: 6rpx 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.level-index {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #9f7b61;
}

.level-title {
  margin-top: 4rpx;
  font-size: 29rpx;
  font-weight: 700;
  color: #8d4f33;
}

.level-note {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(157, 96, 58, 0.1);
  color: #966244;
  font-size: 20rpx;
}
