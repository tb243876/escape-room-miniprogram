.home-stage {
  position: relative;
  margin-top: 4rpx;
}

.home-stage-card {
  position: relative;
  overflow: hidden;
  padding: 26rpx 26rpx 24rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at top right, var(--red-dim), transparent 28%),
    radial-gradient(circle at bottom left, rgba(214, 169, 113, 0.14), transparent 32%),
    linear-gradient(135deg, #4a332c, #6f5043 52%, #d0a06d);
  box-shadow: 0 14rpx 28rpx rgba(67, 39, 21, 0.12);
  color: var(--cream-primary);
  border: 1rpx solid var(--border-red);
}

.home-stage-card::after {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -56rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 228, 179, 0.34), transparent 64%);
}

.home-stage-kicker {
  position: relative;
  z-index: 1;
  width: fit-content;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(245, 240, 235, 0.08);
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--cream-primary);
}

.home-stage-stamp {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border-red);
  background: rgba(39, 24, 18, 0.18);
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--cream-muted);
  transform: rotate(-7deg);
}

.home-stage-title {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  max-width: 560rpx;
  font-size: 40rpx;
  line-height: 1.28;
  font-weight: 700;
}

.home-stage-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  max-width: 620rpx;
  font-size: 23rpx;
  line-height: 1.65;
  color: var(--cream-muted);
}

.home-stage-meta {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.home-stage-meta-item {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 245, 235, 0.12);
  border: 1rpx solid var(--border-red);
  font-size: 20rpx;
  color: var(--cream-primary);
}

.home-search-shell {
  margin-top: 16rpx;
}

.home-search-kicker {
  margin: 0 2rpx 12rpx;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--text-secondary);
}

.home-search-card {
  padding: 18rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 231, 198, 0.2), transparent 32%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
  box-shadow: 0 10rpx 22rpx rgba(94, 62, 39, 0.12);
  border: 1rpx solid var(--border-default);
}

.home-search-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.home-search-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.home-search-record {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.home-search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.home-search-input {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: var(--bg-card-alt);
  color: var(--text-primary);
  font-size: 26rpx;
  border: 1rpx solid var(--border-default);
}

.home-search-clear {
  flex-shrink: 0;
  padding: 0 18rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  color: var(--red-deep);
  font-size: 22rpx;
  font-weight: 700;
}

.level-block {
  margin-bottom: 18rpx;
}

.level-block {
  padding: 20rpx 18rpx 8rpx;
  border-radius: 26rpx;
  border: 1rpx solid var(--border-subtle);
}

.level-block-light {
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(246, 234, 218, 0.98));
}

.level-block-medium {
  background:
    radial-gradient(circle at top right, rgba(239, 205, 164, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(241, 226, 208, 0.98));
}

.level-block-heavy {
  background:
    radial-gradient(circle at top right, rgba(224, 186, 140, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(252, 243, 233, 0.98), rgba(235, 216, 193, 0.98));
}

.compact-theme-card {
  display: flex;
  align-items: center;
  overflow: hidden;
  margin-bottom: 16rpx;
  background:
    linear-gradient(90deg, rgba(212, 167, 107, 0.14) 0, rgba(212, 167, 107, 0.14) 16rpx, transparent 16rpx),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(243, 232, 220, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.compact-cover {
  width: 190rpx;
  height: 190rpx;
  flex-shrink: 0;
  display: block;
}

.compact-body {
  padding: 24rpx;
}

.compact-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--text-secondary);
}

.compact-name {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.horror-stars {
  margin-top: 10rpx;
  font-size: 23rpx;
  letter-spacing: 2rpx;
}

.horror-stars-label {
  color: var(--text-secondary);
}

.horror-star {
  display: inline-block;
  margin-right: 2rpx;
  font-size: 25rpx;
  line-height: 1;
}

.horror-star-active {
  color: var(--red-primary);
  font-size: 25rpx;
  line-height: 1;
  text-shadow: 0 2rpx 6rpx rgba(190, 139, 81, 0.22);
}

.horror-star-inactive {
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 1;
  opacity: 0.95;
}

.compact-desc {
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.compact-meta {
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.7;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-empty {
  padding: 28rpx 24rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  border: 1rpx dashed var(--border-red);
  background: rgba(255, 248, 240, 0.94);
}

.level-title-row {
  margin: 6rpx 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.level-index {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--text-secondary);
}

.level-title {
  margin-top: 4rpx;
  font-size: 29rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.level-note {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  color: var(--red-deep);
  font-size: 20rpx;
}
