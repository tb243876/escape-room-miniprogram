.dashboard-hero {
  padding: 30rpx;
  background:
    linear-gradient(160deg, rgba(22, 12, 10, 0.06), rgba(22, 12, 10, 0)),
    radial-gradient(circle at top right, rgba(239, 198, 135, 0.22), transparent 34%),
    linear-gradient(135deg, #41302a, #6f5043 58%, #c89a65);
  color: #fff3e8;
}

.dashboard-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.dashboard-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
}

.dashboard-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(255, 243, 232, 0.84);
}

.dashboard-permissions {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(255, 243, 232, 0.72);
}

.dashboard-actions {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
}

.dashboard-action-btn {
  max-width: 320rpx;
  min-height: 72rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1.2;
  box-sizing: border-box;
  white-space: nowrap;
}

.staff-entry-grid {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.staff-entry-card {
  padding: 26rpx;
  border: 1rpx solid rgba(122, 73, 48, 0.08);
}

.staff-entry-card-users {
  background:
    radial-gradient(circle at top right, rgba(255, 231, 188, 0.26), transparent 32%),
    linear-gradient(180deg, rgba(255, 249, 240, 0.98), rgba(246, 236, 220, 0.98));
}

.staff-entry-card-sessions {
  background:
    radial-gradient(circle at top right, rgba(223, 241, 218, 0.28), transparent 32%),
    linear-gradient(180deg, rgba(246, 251, 243, 0.98), rgba(231, 241, 225, 0.98));
}

.staff-entry-card-store {
  background:
    radial-gradient(circle at top right, rgba(219, 234, 242, 0.28), transparent 32%),
    linear-gradient(180deg, rgba(241, 248, 252, 0.98), rgba(224, 238, 246, 0.98));
}

.staff-entry-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #8a6c57;
}

.staff-entry-title {
  margin-top: 14rpx;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #4f3125;
}

.staff-entry-meta {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #67584d;
}
