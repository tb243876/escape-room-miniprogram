<view class="screen">
  <view wx:if="{{errorText}}" class="card status-card">
    <view class="status-title">工作台加载失败</view>
    <view class="status-text">{{errorText}}</view>
    <view class="button-primary status-action" bindtap="retryLoad">重新加载</view>
  </view>

  <block wx:elif="{{dashboard}}">
    <view class="hero-card dashboard-hero">
      <view class="dashboard-kicker">门店工作台</view>
      <view class="dashboard-title">{{dashboard.storeName}} · {{dashboard.roleLabel}}</view>
      <view class="dashboard-subtitle">这里只做入口分发，具体功能进入各自页面处理。</view>
      <view class="dashboard-permissions">{{dashboard.permissionsText}}</view>
    </view>

    <view class="dashboard-actions">
      <view class="button-secondary dashboard-action-btn" bindtap="openHighlights">查看集锦库</view>
    </view>

    <view class="staff-entry-grid">
      <view wx:if="{{dashboard.canViewMemberStats}}" class="card staff-entry-card staff-entry-card-users" bindtap="openUsersPage">
        <view class="staff-entry-kicker">用户看板</view>
        <view class="staff-entry-title">查看用户数据</view>
        <view class="staff-entry-meta">累计用户 {{dashboard.memberStats.totalUsers}} · 近30天活跃 {{dashboard.memberStats.activeUsers30d}}</view>
      </view>

      <view class="card staff-entry-card staff-entry-card-sessions" bindtap="openSessionsPage">
        <view class="staff-entry-kicker">场次管理</view>
        <view class="staff-entry-title">处理门店待办</view>
        <view class="staff-entry-meta">待确认 {{dashboard.stats.pendingConfirm}} · 待开始 {{dashboard.stats.readyToStart}}</view>
        <view class="button-primary dashboard-card-btn" bindtap="openSessionsPage">进入场次管理</view>
      </view>

      <view wx:if="{{dashboard.canManageAuthCodes}}" class="card staff-entry-card staff-entry-card-store" bindtap="openStorePage">
        <view class="staff-entry-kicker">门店管理</view>
        <view class="staff-entry-title">管理员工与授权</view>
        <view class="staff-entry-meta">已绑定 {{dashboard.authCodeSummary.activeStaff}} 人 · 最近授权码 {{dashboard.authCodeSummary.latestCode || '暂无'}}</view>
      </view>
    </view>
  </block>
</view>
