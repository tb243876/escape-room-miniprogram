<view class="screen">
  <view wx:if="{{errorText}}" class="card status-card">
    <view class="status-title">队伍房间加载失败</view>
    <view class="status-text">{{errorText}}</view>
    <view class="button-primary status-action" bindtap="retryLoad">重新加载</view>
  </view>

  <block wx:elif="{{room}}">
    <view class="hero-card room-hero">
      <view class="room-kicker">队伍房间</view>
      <view class="room-title">{{room.themeName}} · {{room.playDate}} {{room.timeSlot}}</view>
      <view class="room-subtitle">{{room.stageHint}}</view>
      <view class="room-stage {{room.stageBadgeClass}}">{{room.stageLabel}}</view>
    </view>

    <view class="card room-card">
      <view class="row">
        <view class="room-card-title">当前状态</view>
        <view class="room-card-badge">{{room.memberSummary}}</view>
      </view>
      <view class="room-card-meta">{{room.storeName}} · {{room.statusText}}</view>
    </view>

    <view class="card room-card">
      <view class="room-card-title">队伍成员</view>
      <view wx:if="{{room.members.length}}" class="member-list">
        <view
          class="{{item.memberClass}}"
          wx:for="{{room.members}}"
          wx:key="memberKey"
          bindtap="openMemberCard"
          data-openid="{{item.openId}}"
          data-nickname="{{item.nickname}}"
        >
          <block wx:if="{{item.avatarUrl}}">
            <image class="member-avatar member-avatar-image" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          </block>
          <view wx:else class="member-avatar">{{item.avatarText}}</view>
          <view class="member-copy">
            <view class="member-name-row">
              <view class="member-name">{{item.nickname}}</view>
              <view wx:if="{{item.isCreator}}" class="member-role-tag member-role-tag-owner">发起人</view>
              <view wx:if="{{item.isSelf}}" class="member-role-tag member-role-tag-self">我自己</view>
            </view>
            <view class="member-summary">{{item.summaryText}}</view>
            <view class="{{item.statusClass}}">{{item.status}}</view>
          </view>
        </view>
      </view>
      <view wx:else class="room-empty-hint">暂无成员信息</view>
    </view>

    <view class="card room-card">
      <view class="room-card-title">当前进度</view>
      <view wx:if="{{room.timeline.length}}" class="timeline">
        <view class="timeline-item" wx:for="{{room.timeline}}" wx:key="index">
          <view class="timeline-item-title">{{item.title}}</view>
          <view class="timeline-item-content">{{item.content}}</view>
        </view>
      </view>
      <view wx:else class="room-empty-hint">暂无进度记录</view>
    </view>

    <view wx:if="{{room.canShowResult}}" class="card room-card">
      <view class="room-card-title">本场结果</view>
      <view class="result-grid">
        <view class="result-item">
          <view class="result-num">{{room.resultGrowthText}}</view>
          <view class="result-label">成长值</view>
        </view>
        <view class="result-item">
          <view class="result-num">{{room.resultArchiveText}}</view>
          <view class="result-label">记录更新</view>
        </view>
      </view>
      <view class="result-desc">{{room.result.badgeText}}</view>
    </view>

    <view wx:if="{{room.canShowHighlights}}" class="card room-card">
      <view class="row">
        <view class="room-card-title">本场集锦</view>
        <view class="room-card-badge">48 小时内可见</view>
      </view>
      <view class="highlight-grid">
        <view class="highlight-item" wx:for="{{room.highlights}}" wx:key="id">
          <view class="highlight-visual"></view>
          <view class="highlight-title">{{item.title}}</view>
        </view>
      </view>
    </view>

    <view class="room-actions actions-split">
      <view class="button-secondary" bindtap="contactStore">联系门店</view>
      <view class="button-primary" bindtap="goLobby">回到大厅</view>
    </view>
  </block>

  <view wx:else class="card status-card">
    <view class="status-title">暂无队伍信息</view>
    <view class="status-text">当前还没有可展示的队伍房间，请先返回大厅选择。</view>
    <view class="button-primary status-action" bindtap="goLobby">回到大厅</view>
  </view>

  <view wx:if="{{dialogVisible || selectedMember}}" class="room-mask modal-mask-center" bindtap="closeDialog">
    <view class="room-dialog modal-card-common" catchtap="noop">
      <scroll-view class="room-dialog-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <block wx:if="{{selectedMember}}">
          <view class="player-card-head">
            <block wx:if="{{selectedMember.avatarUrl}}">
              <image class="player-card-avatar-image" src="{{selectedMember.avatarUrl}}" mode="aspectFill"></image>
            </block>
            <view wx:else class="player-card-avatar">{{selectedMember.avatarText}}</view>
            <view class="player-card-copy">
              <view class="player-card-name">{{selectedMember.nickname}}</view>
              <view class="player-card-title">{{selectedMember.titleLabel}}</view>
              <view class="player-card-meta">{{selectedMember.genderText}} · {{selectedMember.summaryText}}</view>
            </view>
          </view>
          <view class="player-card-section">
            <view class="player-card-section-title">个性签名</view>
            <view class="player-card-signature">{{selectedMember.signature}}</view>
          </view>
          <view class="player-card-stats">
            <view class="player-card-stat">
              <view class="player-card-stat-num">{{selectedMember.totalPlayCount}}</view>
              <view class="player-card-stat-label">通关次数</view>
            </view>
            <view class="player-card-stat">
              <view class="player-card-stat-num">{{selectedMember.badgeCount}}</view>
              <view class="player-card-stat-label">荣誉徽章</view>
            </view>
            <view class="player-card-stat">
              <view class="player-card-stat-num">{{selectedMember.growthValue}}</view>
              <view class="player-card-stat-label">成长值</view>
            </view>
          </view>
          <view class="player-card-section">
            <view class="player-card-section-title">当前荣誉</view>
            <view class="player-card-tag-list">
              <view class="player-card-tag" wx:for="{{selectedMember.honorLabels}}" wx:key="*this">{{item}}</view>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="room-dialog-title modal-title-common">{{dialogTitle}}</view>
          <view class="room-dialog-content modal-content-common">{{dialogContent}}</view>
        </block>
      </scroll-view>
      <view class="button-primary room-dialog-btn" bindtap="closeDialog">{{selectedMember ? '关闭资料' : '关闭'}}</view>
    </view>
  </view>
</view>
