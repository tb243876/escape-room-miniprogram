.room-hero {
  padding: 30rpx;
  background:
    linear-gradient(160deg, rgba(22, 12, 10, 0.06), rgba(22, 12, 10, 0)),
    radial-gradient(circle at top right, rgba(239, 198, 135, 0.22), transparent 34%),
    linear-gradient(135deg, #41302a, #6f5043 58%, #c89a65);
  color: #fff3e8;
}

.room-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.room-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.room-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(255, 243, 232, 0.84);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.room-stage {
  margin-top: 18rpx;
  width: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.stage-badge-warn {
  background: rgba(255, 243, 232, 0.18);
  color: #fff3e8;
}

.stage-badge-ready {
  background: rgba(235, 214, 184, 0.22);
  color: #fff1df;
}

.stage-badge-live {
  background: rgba(203, 237, 213, 0.18);
  color: #effff4;
}

.stage-badge-ok {
  background: rgba(242, 236, 205, 0.2);
  color: #fff7da;
}

.stage-badge-archived {
  background: rgba(222, 213, 204, 0.2);
  color: #f4ebe3;
}

.room-card {
  margin-top: 18rpx;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 236, 208, 0.24), transparent 30%),
    linear-gradient(180deg, rgba(255, 249, 242, 0.98), rgba(244, 235, 225, 0.98));
}

.room-card-title {
  font-size: 30rpx;
  font-weight: 700;
}

.room-empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #b0a090;
  text-align: center;
  padding: 20rpx 0;
}

.room-card-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #efe0cb, #e5c7a7);
  color: #8f5231;
  font-size: 22rpx;
}

.room-card-meta {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.75;
  color: #62554a;
}

.member-list {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.member-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(139, 94, 56, 0.08);
  overflow: hidden;
  min-width: 0;
}

.member-item-pending {
  background: linear-gradient(180deg, #fbf3e9, #f2e5d6);
}

.member-item-confirmed {
  background:
    radial-gradient(circle at top right, rgba(222, 241, 221, 0.32), transparent 34%),
    linear-gradient(180deg, #f4fbf2, #e6f1e1);
}

.member-item-live {
  background:
    radial-gradient(circle at top right, rgba(219, 235, 242, 0.3), transparent 34%),
    linear-gradient(180deg, #f0f7fb, #dfeef5);
}

.member-item-settled {
  background:
    radial-gradient(circle at top right, rgba(247, 233, 204, 0.3), transparent 34%),
    linear-gradient(180deg, #fbf6e8, #f2ead1);
}

.member-avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(135deg, #8d3d23, #cf7544);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.member-avatar-image {
  display: block;
  object-fit: cover;
  box-shadow: 0 8rpx 18rpx rgba(122, 62, 37, 0.12);
}

.member-copy {
  min-width: 0;
  flex: 1;
}

.member-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.member-name {
  font-size: 24rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.member-role-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.3;
  font-weight: 700;
}

.member-role-tag-owner {
  background: rgba(159, 92, 48, 0.14);
  color: #8f5231;
}

.member-role-tag-self {
  background: rgba(123, 61, 40, 0.12);
  color: #9e3d22;
}

.member-summary {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #7b6456;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.member-status {
  margin-top: 8rpx;
  font-size: 22rpx;
  width: fit-content;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.member-status-pending {
  background: rgba(157, 96, 58, 0.1);
  color: #7f6d61;
}

.member-status-confirmed {
  background: rgba(100, 154, 102, 0.12);
  color: #4a7850;
}

.member-status-live {
  background: rgba(88, 139, 176, 0.12);
  color: #3d6d90;
}

.member-status-settled {
  background: rgba(185, 152, 69, 0.14);
  color: #8a6d1c;
}

.timeline {
  margin-top: 16rpx;
}

.timeline-item {
  position: relative;
  margin-top: 16rpx;
  padding-left: 24rpx;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #b76a3a, #daaa64);
}

.timeline-item-title {
  font-size: 26rpx;
  font-weight: 700;
}

.timeline-item-content {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #685c51;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.result-item {
  padding: 18rpx;
  border-radius: 18rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 239, 214, 0.26), transparent 30%),
    rgba(255, 249, 242, 0.78);
  border: 1rpx solid rgba(141, 61, 35, 0.08);
}

.result-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #7b4028;
}

.result-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a695d;
}

.result-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #5e5145;
}

.highlight-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.highlight-item {
  padding: 14rpx;
  border-radius: 18rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 230, 188, 0.26), transparent 30%),
    linear-gradient(180deg, #fbf3e9, #f2e5d6);
}

.highlight-visual {
  height: 120rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 232, 194, 0.18), transparent 34%),
    linear-gradient(135deg, #8b5a41, #c49d77);
}

.highlight-title {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.room-actions {
  margin-top: 24rpx;
}

.room-mask {
}

.room-dialog {
  width: 100%;
  max-height: calc(100vh - 160rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.room-dialog-title {
}

.room-dialog-content {
}

.room-dialog-btn {
  width: auto;
  min-width: 188rpx;
  align-self: center;
  margin-top: 18rpx;
  padding: 14rpx 30rpx;
  font-size: 22rpx;
}

.room-dialog-scroll {
  flex: 1;
  min-height: 0;
}

.player-card-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.player-card-avatar,
.player-card-avatar-image {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.player-card-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #8d3d23, #cf7544);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.player-card-copy {
  flex: 1;
  min-width: 0;
}

.player-card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #523628;
}

.player-card-title {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9e3d22;
}

.player-card-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6d503f;
}

.player-card-section {
  margin-top: 22rpx;
}

.player-card-section-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #523628;
}

.player-card-signature {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.8;
  color: #6d503f;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.player-card-stats {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.player-card-stat {
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 249, 242, 0.7);
  border: 1rpx solid rgba(141, 61, 35, 0.08);
  text-align: center;
}

.player-card-stat-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #7b4028;
}

.player-card-stat-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #7a695d;
}

.player-card-tag-list {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.player-card-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #efe0cb, #e5c7a7);
  color: #8f5231;
  font-size: 20rpx;
}
