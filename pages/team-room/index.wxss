.room-hero {
  padding: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.3), transparent 30%),
    radial-gradient(circle at bottom left, rgba(255, 239, 216, 0.2), transparent 32%),
    linear-gradient(135deg, #4a332c, #7b5547 58%, #d0a06d);
  color: var(--cream-primary);
  border: 1rpx solid rgba(141, 98, 60, 0.12);
  box-shadow: 0 16rpx 28rpx rgba(67, 39, 21, 0.12);
}

.room-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.room-pulse {
  margin-top: 12rpx;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--red-primary);
}

.room-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.room-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--cream-muted);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.room-stage {
  margin-top: 18rpx;
  width: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.stage-badge-warn {
  background: rgba(239, 68, 68, 0.12);
  color: #ffd9d9;
}

.stage-badge-ready {
  background: rgba(245, 158, 11, 0.12);
  color: #ffe6bf;
}

.stage-badge-live {
  background: rgba(158, 61, 34, 0.12);
  color: var(--red-deep);
}

.stage-badge-ok {
  background: rgba(34, 197, 94, 0.12);
  color: #dff8e7;
}

.stage-badge-archived {
  background: rgba(107, 114, 128, 0.14);
  color: #e5e7eb;
}

.room-card {
  margin-top: 18rpx;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(245, 236, 226, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.room-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.room-empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  text-align: center;
  padding: 20rpx 0;
}

.room-card-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  color: var(--red-deep);
  border: 1rpx solid var(--border-red);
  font-size: 22rpx;
}

.room-card-meta {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.75;
  color: var(--text-secondary);
}

.room-overview-grid {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.room-overview-item {
  flex: 1 1 180rpx;
  min-width: 180rpx;
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 245, 231, 0.9);
  border: 1rpx solid rgba(148, 101, 64, 0.1);
}

.room-overview-label {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.room-overview-value {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #7b4a31;
}

.member-list {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.member-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--border-subtle);
  overflow: hidden;
  min-width: 0;
}

.member-item-pending {
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(241, 234, 226, 0.98));
}

.member-item-confirmed {
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.22), transparent 34%),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(241, 234, 226, 0.98));
}

.member-item-live {
  background:
    radial-gradient(circle at top right, rgba(255, 230, 188, 0.22), transparent 34%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
}

.member-item-settled {
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.2), transparent 34%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
}

.member-avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
  color: var(--cream-primary);
  font-size: 24rpx;
  font-weight: 700;
}

.member-avatar-image {
  display: block;
  object-fit: cover;
  box-shadow: 0 8rpx 18rpx rgba(94, 62, 39, 0.12);
}

.member-copy {
  min-width: 0;
  flex: 1;
}

.member-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.member-name {
  font-size: 24rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.member-role-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.3;
  font-weight: 700;
}

.member-role-tag-owner {
  background: var(--red-dim);
  color: var(--red-primary);
}

.member-role-tag-self {
  background: rgba(255, 244, 233, 0.9);
  color: var(--red-deep);
}

.member-reputation-warn {
  background: rgba(239, 68, 68, 0.12);
  color: #b63b3b;
  border: 1rpx solid rgba(239, 68, 68, 0.18);
}

.member-summary {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.member-risk-note {
  margin-top: 8rpx;
  padding: 8rpx 10rpx;
  border-radius: 14rpx;
  background: rgba(239, 68, 68, 0.06);
  border: 1rpx solid rgba(239, 68, 68, 0.12);
  font-size: 18rpx;
  line-height: 1.55;
  color: #9f3f3f;
}

.member-status {
  margin-top: 8rpx;
  font-size: 22rpx;
  width: fit-content;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.member-status-pending {
  background: rgba(245, 158, 11, 0.1);
  color: var(--status-pending);
}

.member-status-confirmed {
  background: rgba(62, 207, 142, 0.1);
  color: var(--status-open);
}

.member-status-live {
  background: var(--red-dim);
  color: var(--red-deep);
}

.member-status-settled {
  background: rgba(245, 158, 11, 0.12);
  color: var(--status-full);
}

.timeline {
  margin-top: 16rpx;
}

.timeline-item {
  position: relative;
  margin-top: 16rpx;
  padding-left: 24rpx;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--red-primary);
}

.timeline-item-title {
  font-size: 26rpx;
  font-weight: 700;
}

.timeline-item-content {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.result-item {
  padding: 18rpx;
  border-radius: 18rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 231, 198, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(243, 232, 220, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.result-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--red-deep);
}

.result-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.result-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: var(--text-secondary);
}

.highlight-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.highlight-item {
  padding: 14rpx;
  border-radius: 18rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(255, 250, 244, 0.98), rgba(243, 232, 220, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.highlight-visual {
  height: 120rpx;
  overflow: hidden;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at top left, rgba(255, 232, 202, 0.18), transparent 34%),
    linear-gradient(135deg, #8b5a41, #c49d77);
}

.highlight-image {
  width: 100%;
  height: 100%;
}

.highlight-video-icon {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--cream-primary);
}

.highlight-title {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.room-actions {
  margin-top: 24rpx;
}

.room-mask {
}

.room-dialog {
  width: 100%;
  max-height: calc(100vh - 160rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.room-dialog-title {
}

.room-dialog-content {
}

.room-dialog-btn {
  width: auto;
  min-width: 188rpx;
  align-self: center;
  margin-top: 18rpx;
  padding: 14rpx 30rpx;
  font-size: 22rpx;
}

.room-dialog-scroll {
  flex: 1;
  min-height: 0;
}
