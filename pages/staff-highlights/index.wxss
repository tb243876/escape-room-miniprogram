.staff-highlights-hero {
  padding: 30rpx;
  background:
    linear-gradient(160deg, rgba(22, 12, 10, 0.06), rgba(22, 12, 10, 0)),
    radial-gradient(circle at top right, rgba(239, 198, 135, 0.22), transparent 34%),
    linear-gradient(135deg, #41302a, #6f5043 58%, #c89a65);
  color: #fff3e8;
}

.staff-highlights-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.staff-highlights-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.staff-highlights-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(255, 243, 232, 0.84);
}

.highlight-pack {
  margin-top: 18rpx;
  padding: 24rpx;
}

.highlight-pack-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
}

.highlight-pack-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-ok {
  background: linear-gradient(135deg, #dff2df, #cbe8cb);
  color: #3a7241;
}

.status-pending {
  background: linear-gradient(135deg, #efe0cb, #e5c7a7);
  color: #8f5231;
}

.highlight-pack-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #62554a;
}

.highlight-media-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.highlight-media-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fcf4eb, #f3e6d8);
}

.highlight-media-visual {
  width: 92rpx;
  height: 92rpx;
  border-radius: 20rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 240, 204, 0.32), transparent 30%),
    linear-gradient(135deg, #7d5644, #c89a65);
}

.highlight-media-copy {
  flex: 1;
  min-width: 0;
}

.highlight-media-title {
  font-size: 26rpx;
  font-weight: 600;
}

.highlight-media-tag {
  margin-top: 8rpx;
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.55);
  color: #7b4a31;
  font-size: 20rpx;
}

.highlight-empty {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fcf4eb, #f3e6d8);
  color: #8a5d42;
  font-size: 24rpx;
  line-height: 1.7;
}
