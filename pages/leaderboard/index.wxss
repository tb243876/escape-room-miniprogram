.leaderboard-hero {
  padding: 30rpx;
  background:
    linear-gradient(135deg, #4a2d24 0%, #815542 100%);
  color: var(--cream-primary);
  border-bottom: 1rpx solid var(--border-red);
}

.leaderboard-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.leaderboard-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
}

.leaderboard-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--cream-muted);
}

.leaderboard-summary {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.leaderboard-period-tabs {
  margin-top: 18rpx;
  display: inline-flex;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 249, 242, 0.92);
  border: 1rpx solid var(--border-subtle);
  gap: 8rpx;
}

.leaderboard-period-tab {
  min-width: 136rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.leaderboard-period-tab-active {
  background: linear-gradient(135deg, #8d5f34, #c78d60);
  color: var(--cream-primary);
  box-shadow: 0 10rpx 20rpx rgba(94, 62, 39, 0.14);
}

.leaderboard-hero-tags {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.leaderboard-hero-tag {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 233, 0.12);
  border: 1rpx solid var(--border-red);
  font-size: 20rpx;
  color: var(--cream-primary);
}

.leaderboard-summary-card {
  padding: 22rpx 16rpx;
  text-align: center;
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.leaderboard-summary-num {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--red-deep);
}

.leaderboard-summary-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.leaderboard-card {
  margin-top: 18rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.leaderboard-card-top {
  background:
    linear-gradient(135deg, #7b5a46, #a68062);
  color: var(--cream-primary);
  border: 1rpx solid var(--red-primary);
}

.leaderboard-card-rank {
  width: 108rpx;
  min-width: 108rpx;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 22rpx;
  background: var(--bg-card-alt);
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 700;
}

.leaderboard-card-top .leaderboard-card-rank {
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
  color: var(--cream-primary);
}

.leaderboard-card-copy {
  flex: 1;
  min-width: 0;
}

.leaderboard-card-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.leaderboard-card-name {
  font-size: 30rpx;
  font-weight: 700;
}

.leaderboard-card-title {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  color: var(--red-deep);
  font-size: 20rpx;
  font-weight: 700;
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: inline-block;
}

.leaderboard-card-top .leaderboard-card-title {
  background: rgba(255, 244, 233, 0.12);
  color: var(--cream-primary);
}

.leaderboard-card-meta {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.leaderboard-card-top .leaderboard-card-meta,
.leaderboard-card-top .leaderboard-card-name {
  color: var(--cream-primary);
}

.leaderboard-card-score {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--red-primary);
}

.leaderboard-card-top .leaderboard-card-score {
  color: var(--cream-primary);
}

.leaderboard-avatar,
.leaderboard-avatar-image {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.leaderboard-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
  color: var(--cream-primary);
  font-size: 28rpx;
  font-weight: 700;
}

.leaderboard-avatar-image {
  display: block;
}

.leaderboard-player-dialog {
  width: 100%;
  max-height: calc(100vh - 160rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.leaderboard-player-scroll {
  flex: 1;
  min-height: 0;
}

.leaderboard-player-btn {
  width: auto;
  min-width: 188rpx;
  align-self: center;
  margin-top: 18rpx;
  padding: 14rpx 30rpx;
  font-size: 22rpx;
}
