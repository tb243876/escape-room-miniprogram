<view class="screen">
  <view class="hero-card leaderboard-hero">
    <view class="leaderboard-kicker">玩家排行榜</view>
    <view class="leaderboard-title">完成主题后，成长值和徽章会自动沉淀到榜单</view>
    <view class="leaderboard-subtitle">榜单按成长值排序，资料卡会同步展示通关记录与荣誉标签</view>
    <view class="leaderboard-hero-tags">
      <view class="leaderboard-hero-tag">{{activePeriod === 'month' ? '近30天榜' : '全时间总榜'}}</view>
      <view class="leaderboard-hero-tag">点击可看玩家资料</view>
    </view>
  </view>

  <view class="leaderboard-period-tabs">
    <view
      wx:for="{{periodTabs}}"
      wx:key="key"
      class="leaderboard-period-tab {{item.active ? 'leaderboard-period-tab-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="changePeriod"
    >{{item.text}}</view>
  </view>

  <view wx:if="{{errorText}}" class="card status-card">
    <view class="status-title">排行榜加载失败</view>
    <view class="status-text">{{errorText}}</view>
    <view class="button-primary status-action" bindtap="retryLoad">重新加载</view>
  </view>

  <block wx:elif="{{summary}}">
    <view class="leaderboard-summary">
      <view
        class="card leaderboard-summary-card"
        wx:for="{{summaryCards}}"
        wx:key="key"
      >
        <view class="leaderboard-summary-num">{{item.value}}</view>
        <view class="leaderboard-summary-label">{{item.label}}</view>
      </view>
    </view>

    <view class="section-title">
      <text>{{activePeriod === 'month' ? '近30天排名' : '总榜排名'}}</text>
    </view>

    <view wx:if="{{leaderboard.length}}">
      <view
        class="card leaderboard-card {{item.cardClass}}"
        wx:for="{{leaderboard}}"
        wx:key="rank"
        data-openid="{{item.openId}}"
        data-rank="{{item.rank}}"
        bindtap="openPlayerCard"
      >
        <view class="leaderboard-card-rank">{{item.medalText}}</view>
        <block wx:if="{{item.avatarUrl}}">
          <image class="leaderboard-avatar leaderboard-avatar-image" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        </block>
        <view wx:else class="leaderboard-avatar">{{item.avatarText}}</view>
        <view class="leaderboard-card-copy">
          <view class="leaderboard-card-name-row">
            <view class="leaderboard-card-name">{{item.nickname}}</view>
            <view wx:if="{{item.titleLabel}}" class="leaderboard-card-title">{{item.titleLabel}}</view>
          </view>
          <view class="leaderboard-card-meta">{{item.summaryText}}</view>
        </view>
        <view class="leaderboard-card-score">+{{item.growthValue}}</view>
      </view>
    </view>

    <view wx:else class="card status-card">
      <view class="status-title">暂无榜单数据</view>
      <view class="status-text">完成主题后会自动登榜</view>
    </view>
  </block>

  <view wx:if="{{selectedPlayer}}" class="modal-mask-center" bindtap="closePlayerCard">
    <view class="modal-card-common leaderboard-player-dialog" catchtap="noop">
      <scroll-view class="leaderboard-player-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <view class="player-card-head">
          <block wx:if="{{selectedPlayer.avatarUrl}}">
            <image class="player-card-avatar-image" src="{{selectedPlayer.avatarUrl}}" mode="aspectFill"></image>
          </block>
          <view wx:else class="player-card-avatar">{{selectedPlayer.avatarText}}</view>
          <view class="player-card-copy">
            <view class="player-card-name">{{selectedPlayer.nickname}}</view>
            <view class="player-card-title">{{selectedPlayer.titleLabel}}</view>
            <view class="player-card-meta">{{selectedPlayer.genderText}} · {{selectedPlayer.summaryText}}</view>
          </view>
        </view>
        <view class="player-card-section">
          <view class="player-card-section-title">个性签名</view>
          <view class="player-card-signature">{{selectedPlayer.signature}}</view>
        </view>
        <view class="player-card-stats">
          <view class="player-card-stat">
            <view class="player-card-stat-num">{{selectedPlayer.totalPlayCount}}</view>
            <view class="player-card-stat-label">通关次数</view>
          </view>
          <view class="player-card-stat">
            <view class="player-card-stat-num">{{selectedPlayer.badgeCount}}</view>
            <view class="player-card-stat-label">荣誉徽章</view>
          </view>
          <view class="player-card-stat">
            <view class="player-card-stat-num">{{selectedPlayer.growthValue}}</view>
            <view class="player-card-stat-label">成长值</view>
          </view>
        </view>
        <view class="player-card-section">
          <view class="player-card-section-title">当前荣誉</view>
          <view class="player-card-tag-list">
            <view class="player-card-tag" wx:for="{{selectedPlayer.honorLabels}}" wx:key="*this">{{item}}</view>
          </view>
        </view>
      </scroll-view>
      <view class="button-primary leaderboard-player-btn" bindtap="closePlayerCard">关闭资料</view>
    </view>
  </view>
</view>
