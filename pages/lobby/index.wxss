.lobby-summary-strip {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.lobby-atmosphere-card {
  margin-top: 12rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at top right, var(--red-dim), transparent 30%),
    linear-gradient(135deg, rgba(255, 249, 242, 0.96), rgba(245, 236, 226, 0.94));
  border: 1rpx solid var(--border-default);
  box-shadow: 0 16rpx 28rpx rgba(67, 39, 21, 0.1);
  color: var(--text-primary);
}

.lobby-atmosphere-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #9c6e48;
}

.lobby-atmosphere-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.55;
  font-weight: 700;
  color: #7b4a31;
}

.lobby-atmosphere-tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.lobby-atmosphere-tag {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  border: 1rpx solid var(--border-red);
  font-size: 21rpx;
  color: #7b4a31;
}

.lobby-summary-card {
  padding: 18rpx 16rpx 16rpx;
  border-radius: 20rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.2), transparent 28%),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(245, 236, 226, 0.98));
  border: 1rpx solid var(--border-subtle);
  text-align: center;
}

.lobby-summary-value {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--text-primary);
}

.lobby-summary-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.lobby-hall-note {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--text-secondary);
  padding: 12rpx 4rpx 2rpx;
}

.lobby-filter-scroll {
  margin-top: 2rpx;
  white-space: nowrap;
}

.lobby-filter-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 4rpx;
}

.lobby-filter-chip,
.lobby-subfilter-chip {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 22rpx;
  white-space: nowrap;
  font-weight: 600;
}

.lobby-filter-chip {
  padding: 14rpx 22rpx;
  background: var(--bg-card);
  color: var(--text-muted);
  border: 1rpx solid var(--border-subtle);
}

.lobby-filter-chip-active,
.lobby-subfilter-chip-active {
  background: rgba(246, 234, 218, 0.98);
  color: var(--red-primary);
  border-color: var(--red-primary);
  box-shadow: 0 10rpx 20rpx rgba(94, 62, 39, 0.12);
}

.lobby-filter-chip-active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -10rpx;
  width: 34rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: var(--red-primary);
  transform: translateX(-50%);
}

.lobby-toolbar {
  margin-top: 18rpx;
}

.lobby-subfilter-scroll {
  white-space: nowrap;
}

.lobby-subfilter-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 6rpx;
}

.lobby-subfilter-chip {
  min-height: 64rpx;
  padding: 0 22rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-subtle);
  color: var(--text-muted);
}

.lobby-owner-card,
.lobby-member-card,
.lobby-public-card {
  margin-top: 10rpx;
  overflow: hidden;
}

.lobby-owner-card {
  padding: 18rpx;
  background:
    radial-gradient(circle at top right, var(--red-dim), transparent 30%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.98), rgba(246, 234, 218, 0.98));
  border-color: var(--border-default);
  box-shadow: 0 14rpx 28rpx rgba(67, 39, 21, 0.1);
  position: relative;
}

.lobby-owner-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10rpx;
}

.lobby-owner-head-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.lobby-owner-kicker {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--text-secondary);
}

.lobby-owner-title {
  margin-top: 6rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 420rpx;
}

.lobby-owner-seal {
  min-width: 104rpx;
  padding: 8rpx 8rpx;
  text-align: center;
  border-radius: 18rpx;
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
  color: var(--cream-primary);
  font-size: 17rpx;
  font-weight: 700;
}

.lobby-status-pill {
  padding: 5rpx 10rpx;
  border-radius: 999rpx;
  font-size: 17rpx;
  font-weight: 700;
  line-height: 1;
  border: 1rpx solid transparent;
}

.status-pill-recruiting {
  background: rgba(62, 207, 142, 0.1);
  border-color: rgba(62, 207, 142, 0.2);
  color: var(--status-open);
}

.status-pill-pending {
  background: rgba(245, 158, 11, 0.1);
  border-color: rgba(245, 158, 11, 0.2);
  color: var(--status-pending);
}

.status-pill-confirmed {
  background: rgba(62, 207, 142, 0.1);
  border-color: rgba(62, 207, 142, 0.2);
  color: var(--status-open);
}

.status-pill-full {
  background: rgba(245, 158, 11, 0.12);
  border-color: rgba(245, 158, 11, 0.2);
  color: var(--status-full);
}

.status-pill-cancelled {
  background: rgba(255, 92, 106, 0.1);
  border-color: rgba(255, 92, 106, 0.2);
  color: var(--status-danger);
}

.status-pill-default {
  background: var(--bg-card-alt);
  color: var(--text-secondary);
}

.lobby-owner-meta,
.lobby-owner-note {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.45;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.lobby-member-preview {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.45;
  color: var(--text-secondary);
}

.lobby-member-preview-label {
  color: var(--text-secondary);
  margin-right: 10rpx;
}

.lobby-owner-grid {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
}

.lobby-owner-stat {
  min-height: 72rpx;
  padding: 12rpx;
  border-radius: 14rpx;
  background: var(--bg-card-alt);
  border: 1rpx solid var(--border-subtle);
}

.lobby-owner-stat-label {
  font-size: 18rpx;
  color: var(--text-secondary);
}

.lobby-owner-stat-value {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.35;
  color: var(--text-primary);
}

.lobby-member-card {
  padding: 0;
  background: transparent;
  border: none;
  box-shadow: none;
}

.lobby-member-ticket {
  display: flex;
  min-height: 154rpx;
  overflow: hidden;
  border-radius: 24rpx;
  border: 1rpx solid var(--border-subtle);
  background:
    radial-gradient(circle at top right, rgba(255, 228, 186, 0.18), transparent 28%),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(246, 234, 218, 0.98));
  box-shadow: 0 14rpx 26rpx rgba(94, 62, 39, 0.12);
  position: relative;
}

.lobby-member-side {
  width: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #7b4a31, #c49d77);
}

.lobby-member-side-text {
  writing-mode: vertical-rl;
  letter-spacing: 4rpx;
  color: var(--cream-primary);
  font-size: 17rpx;
  font-weight: 700;
}

.lobby-member-main {
  flex: 1;
  padding: 14rpx 14rpx 14rpx 16rpx;
}

.lobby-member-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.lobby-member-top-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.lobby-member-title {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 360rpx;
}

.lobby-member-badge {
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  color: var(--red-deep);
  font-size: 17rpx;
}

.lobby-member-meta {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.45;
  color: var(--text-secondary);
}

.lobby-member-risk {
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx dashed var(--border-red);
  font-size: 18rpx;
  line-height: 1.4;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.lobby-public-card {
  position: relative;
  padding: 18rpx;
  background:
    linear-gradient(90deg, rgba(212, 167, 107, 0.14) 0, rgba(212, 167, 107, 0.14) 16rpx, transparent 16rpx),
    radial-gradient(circle at top right, rgba(255, 231, 198, 0.18), transparent 24%),
    linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(243, 232, 220, 0.98));
  border: 1rpx solid var(--border-subtle);
}

.lobby-public-notch {
  position: absolute;
  top: 50%;
  width: 22rpx;
  height: 22rpx;
  margin-top: -11rpx;
  border-radius: 50%;
  background: var(--bg-base);
  border: 1rpx solid var(--border-subtle);
}

.lobby-public-notch-left {
  left: -11rpx;
}

.lobby-public-notch-right {
  right: -11rpx;
}

.lobby-public-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.lobby-public-kicker {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--text-secondary);
  text-transform: none;
}

.lobby-public-status {
  box-shadow: 0 8rpx 18rpx rgba(94, 62, 39, 0.12);
}

.lobby-public-title {
  margin-top: 8rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lobby-public-meta,
.lobby-public-note,
.lobby-public-tip {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.45;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.lobby-public-foot {
  margin-top: 12rpx;
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  background:
    repeating-linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.2) 0,
      rgba(255, 255, 255, 0.2) 10rpx,
      rgba(255, 255, 255, 0) 10rpx,
      rgba(255, 255, 255, 0) 20rpx
    ),
    linear-gradient(180deg, rgba(255, 244, 233, 0.96), rgba(241, 227, 210, 0.96));
}

.lobby-card-actions {
  margin-top: 12rpx;
}

.lobby-cancel-btn {
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
}

.lobby-card-actions .button-primary,
.lobby-card-actions .button-secondary {
  min-width: 0;
  min-height: 68rpx;
  padding: 0 16rpx;
  font-size: 21rpx;
  box-sizing: border-box;
}

.lobby-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: var(--bg-overlay);
}

.lobby-sheet {
  width: 100%;
  padding: 20rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.22), transparent 34%),
    linear-gradient(180deg, #fff8f1, #ead8c3);
  box-sizing: border-box;
}

.lobby-sheet-handle {
  width: 78rpx;
  height: 8rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: var(--border-default);
}

.lobby-sheet-title {
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  color: var(--text-primary);
}

.lobby-sheet-options {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.lobby-sheet-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: var(--bg-card-alt);
  border: 1rpx solid var(--border-subtle);
  color: var(--text-secondary);
  font-size: 26rpx;
  box-sizing: border-box;
}

.lobby-sheet-option-active {
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
  border-color: transparent;
  color: var(--cream-primary);
}

.lobby-sheet-option-mark {
  font-size: 20rpx;
  opacity: 0.88;
}

.lobby-sheet-cancel {
  margin-top: 18rpx;
  min-height: 88rpx;
  border-radius: 24rpx;
  background: var(--bg-card-alt);
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lobby-sheet-secondary {
  margin-top: 18rpx;
  min-height: 84rpx;
  border-radius: 22rpx;
  border: 1rpx solid var(--border-default);
  color: var(--text-secondary);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 246, 236, 0.9);
}

.lobby-dialog {
  width: 630rpx;
  align-self: center;
}

.lobby-penalty-preview {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 214, 170, 0.24), transparent 30%),
    linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(245, 234, 221, 0.98));
  border: 1rpx solid rgba(183, 81, 63, 0.16);
}

.lobby-penalty-preview-head {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.lobby-penalty-preview-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.lobby-penalty-preview-card {
  min-height: 92rpx;
  padding: 12rpx 10rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(183, 81, 63, 0.12);
  box-sizing: border-box;
}

.lobby-penalty-preview-value {
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--red-deep);
}

.lobby-penalty-preview-label {
  margin-top: 8rpx;
  font-size: 18rpx;
  color: var(--text-secondary);
}

.lobby-penalty-preview-tags {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.lobby-penalty-tag {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: var(--red-dim);
  border: 1rpx solid var(--border-red);
  font-size: 20rpx;
  color: var(--red-deep);
}

.lobby-penalty-preview-note {
  margin-top: 14rpx;
  font-size: 21rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.lobby-exit-reason-options {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.lobby-exit-reason-option {
  min-height: 78rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 248, 240, 0.96);
  border: 1rpx solid var(--border-default);
  color: var(--text-primary);
  font-size: 24rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

.lobby-exit-reason-option-active {
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
  border-color: transparent;
  color: var(--cream-primary);
  box-shadow: 0 10rpx 20rpx rgba(94, 62, 39, 0.14);
}

.lobby-join-fields {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.lobby-join-input {
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid var(--border-default);
  background: rgba(255, 248, 240, 0.96);
  font-size: 26rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.lobby-join-input-error {
  border-color: rgba(183, 81, 63, 0.4);
}

.lobby-join-error {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--status-danger);
}

.lobby-dialog-actions {
  margin-top: 26rpx;
}

.lobby-dialog-btn {
  flex: 1;
  min-height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.lobby-dialog-btn-secondary {
  background: var(--bg-card-alt);
  color: var(--text-secondary);
}

.lobby-dialog-btn-primary {
  background: linear-gradient(135deg, var(--red-deep), var(--red-primary));
  color: var(--cream-primary);
}
