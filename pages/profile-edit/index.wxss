.edit-hero {
  padding: 30rpx;
  background:
    linear-gradient(160deg, rgba(22, 12, 10, 0.06), rgba(22, 12, 10, 0)),
    radial-gradient(circle at top right, rgba(239, 198, 135, 0.22), transparent 34%),
    linear-gradient(135deg, #4a332c, #7b5547 58%, #d0a06d);
  color: #fff3e8;
}

.edit-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.edit-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
}

.edit-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(255, 243, 232, 0.84);
}

.edit-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.edit-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #46332a;
}

.avatar-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.edit-avatar,
.edit-avatar-image {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.edit-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #8d3d23, #cf7544);
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
}

.avatar-btn {
  margin: 0;
}

.field-block {
  margin-top: 18rpx;
}

.field-label {
  margin-bottom: 10rpx;
  font-size: 23rpx;
  color: #745f52;
}

.edit-input,
.picker-field,
.edit-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: #f7f0e8;
  border: 1rpx solid rgba(113, 81, 55, 0.12);
  color: #2f2621;
  font-size: 28rpx;
}

.edit-input,
.picker-field {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
}

.edit-textarea {
  padding: 22rpx 24rpx;
  min-height: 150rpx;
  line-height: 1.7;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #9a7559;
}

.avatar-btn {
  min-width: 164rpx;
  padding: 0 22rpx;
  line-height: 76rpx;
  font-size: 24rpx;
}

.edit-input,
.picker-field,
.edit-textarea {
  box-sizing: border-box;
}

.edit-input-error {
  border-color: rgba(171, 70, 40, 0.48);
  box-shadow: 0 0 0 2rpx rgba(171, 70, 40, 0.08);
}

.form-error {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #ab4628;
}

.edit-title-badge,
.honor-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #efe0cb, #e5c7a7);
  color: #8f5231;
  font-size: 20rpx;
}

.honor-list {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.edit-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 18rpx;
}

.edit-actions view {
  flex: 1;
}

.edit-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(38, 24, 16, 0.42);
}

.edit-sheet {
  width: 100%;
  padding: 20rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background:
    radial-gradient(circle at top right, rgba(255, 232, 202, 0.3), transparent 34%),
    linear-gradient(180deg, #fffaf5, #f5e8d8);
  box-sizing: border-box;
}

.edit-sheet-handle {
  width: 78rpx;
  height: 8rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: rgba(134, 95, 62, 0.2);
}

.edit-sheet-title {
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  color: #523628;
}

.edit-sheet-options {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.edit-sheet-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(173, 127, 80, 0.1);
  color: #694734;
  font-size: 26rpx;
  box-sizing: border-box;
}

.edit-sheet-option-active {
  background: linear-gradient(135deg, #7b4a31, #a96640 62%, #d4a169);
  border-color: transparent;
  color: #fff5ec;
}

.edit-sheet-option-mark {
  font-size: 20rpx;
  opacity: 0.88;
}

.edit-sheet-cancel {
  margin-top: 18rpx;
  min-height: 88rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #6f4933;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
