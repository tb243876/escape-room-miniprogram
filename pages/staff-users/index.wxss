.users-hero {
  padding: 30rpx;
  background:
    linear-gradient(160deg, rgba(22, 12, 10, 0.06), rgba(22, 12, 10, 0)),
    radial-gradient(circle at top right, rgba(239, 198, 135, 0.22), transparent 34%),
    linear-gradient(135deg, #41302a, #6f5043 58%, #c89a65);
  color: #fff3e8;
}

.users-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.users-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
}

.users-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(255, 243, 232, 0.84);
}

.stat-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-item {
  padding: 22rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 231, 188, 0.24), transparent 32%),
    linear-gradient(180deg, rgba(255, 249, 240, 0.98), rgba(246, 236, 220, 0.98));
  border: 1rpx solid rgba(122, 73, 48, 0.08);
}

.stat-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #7b4028;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a695d;
}

.insight-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.insight-card {
  padding: 24rpx;
}

.insight-title {
  font-size: 28rpx;
  font-weight: 700;
}

.insight-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #8d4d2e;
}

.insight-note {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #62554a;
}
