.staff-session-hero {
  padding: 30rpx;
  background:
    linear-gradient(160deg, rgba(22, 12, 10, 0.06), rgba(22, 12, 10, 0)),
    radial-gradient(circle at top right, rgba(239, 198, 135, 0.22), transparent 34%),
    linear-gradient(135deg, #41302a, #6f5043 58%, #c89a65);
  color: #fff3e8;
}

.staff-session-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.staff-session-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
}

.staff-session-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(255, 243, 232, 0.84);
}

.staff-session-meta {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 243, 232, 0.72);
}

.staff-session-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(97, 64, 42, 0.08);
}

.staff-session-card-stage {
  background:
    radial-gradient(circle at top right, rgba(255, 231, 188, 0.24), transparent 30%),
    linear-gradient(180deg, rgba(255, 249, 240, 0.98), rgba(246, 236, 220, 0.98));
}

.staff-session-card-members {
  background:
    linear-gradient(160deg, rgba(84, 58, 43, 0.04), rgba(84, 58, 43, 0)),
    linear-gradient(180deg, rgba(250, 245, 238, 0.98), rgba(243, 234, 224, 0.98));
}

.staff-session-card-timeline {
  background:
    radial-gradient(circle at top right, rgba(228, 216, 198, 0.22), transparent 30%),
    linear-gradient(180deg, rgba(249, 243, 235, 0.98), rgba(240, 231, 221, 0.98));
}

.staff-session-card-actions {
  background:
    radial-gradient(circle at top right, rgba(255, 236, 208, 0.26), transparent 30%),
    linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(245, 235, 224, 0.98));
}

.staff-session-card-title {
  font-size: 30rpx;
  font-weight: 700;
}

.stage-row {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.stage-chip {
  padding: 12rpx 16rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fbf3e9, #f2e5d6);
  color: #7b4a31;
  font-size: 22rpx;
  border: 1rpx solid rgba(123, 74, 49, 0.06);
}

.stage-chip.active {
  background: linear-gradient(135deg, #6b3429, #a95f3b 62%, #d0a060);
  color: #fff4ea;
}

.staff-session-note {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.75;
  color: #62554a;
}

.staff-session-member {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fcf4eb, #f3e6d8);
  border: 1rpx solid rgba(141, 98, 60, 0.08);
}

.staff-session-progress {
  margin-top: 14rpx;
  font-size: 23rpx;
  color: #8f5231;
}

.staff-session-member-copy {
  flex: 1;
  min-width: 0;
}

.staff-session-member-name {
  font-size: 26rpx;
  font-weight: 600;
}

.staff-session-member-status {
  font-size: 22rpx;
  color: #8f5231;
}

.staff-session-member-toggle {
  flex-shrink: 0;
  min-width: 136rpx;
  min-height: 62rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(157, 96, 58, 0.1);
  color: #8f5231;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.22);
}

.staff-session-member-toggle-on {
  background: linear-gradient(135deg, #6b8f63, #8eb285);
  color: #f6fff2;
  box-shadow: 0 10rpx 20rpx rgba(96, 140, 101, 0.18);
}

.staff-session-timeline-item {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-left: 6rpx solid #c89662;
  background:
    radial-gradient(circle at top right, rgba(255, 237, 211, 0.22), transparent 30%),
    linear-gradient(180deg, rgba(252, 244, 235, 0.92), rgba(243, 230, 216, 0.92));
  border-radius: 0 18rpx 18rpx 0;
}

.action-list .button-primary,
.action-list .button-secondary {
  min-width: 220rpx;
}

.staff-session-timeline-title {
  font-size: 24rpx;
  font-weight: 600;
}

.staff-session-timeline-content {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #62554a;
}

.action-list {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.staff-session-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  background: rgba(38, 24, 16, 0.42);
}

.staff-session-dialog {
  width: 100%;
  padding: 34rpx 30rpx 28rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 229, 194, 0.28), transparent 30%),
    linear-gradient(180deg, #fffaf5, #f5e8d8);
  box-sizing: border-box;
}

.staff-session-dialog-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  color: #523628;
}

.staff-session-dialog-content {
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.8;
  text-align: center;
  color: #6d503f;
}

.staff-session-dialog-actions {
  margin-top: 26rpx;
  display: flex;
  gap: 16rpx;
}

.staff-session-dialog-btn {
  flex: 1;
  min-height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.staff-session-dialog-btn-secondary {
  background: rgba(255, 255, 255, 0.84);
  color: #79543c;
}

.staff-session-dialog-btn-primary {
  background: linear-gradient(135deg, #7b4a31, #b86d44 62%, #d6a060);
  color: #fff5eb;
}

.staff-session-dialog-btn-single {
  background: linear-gradient(135deg, #7b4a31, #b86d44 62%, #d6a060);
  color: #fff5eb;
  flex: 0 0 auto;
  min-width: 188rpx;
  min-height: 68rpx;
  margin: 0 auto;
  padding: 0 30rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
}
