.create-hero {
  padding: 30rpx;
  background:
    linear-gradient(160deg, rgba(22, 12, 10, 0.06), rgba(22, 12, 10, 0)),
    radial-gradient(circle at top right, rgba(239, 198, 135, 0.22), transparent 34%),
    linear-gradient(135deg, #41302a, #6f5043 58%, #c89a65);
  color: #fff3e8;
}

.create-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.create-title {
  margin-top: 18rpx;
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
}

.create-subtitle {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: rgba(255, 243, 232, 0.84);
}

.form-card {
  margin-top: 18rpx;
  padding: 28rpx;
}

.field-row {
  display: flex;
  gap: 18rpx;
}

.field-half {
  flex: 1;
}

.field-label {
  margin-top: 20rpx;
  margin-bottom: 12rpx;
  font-size: 25rpx;
  color: #5e4f43;
}

.picker-field,
.input-field,
.textarea-field {
  width: 100%;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: #f7f0e8;
  border: 1rpx solid rgba(113, 81, 55, 0.12);
  color: #2f2621;
  font-size: 28rpx;
}

.picker-field,
.input-field {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
}

.textarea-field {
  padding: 22rpx 24rpx;
  min-height: 150rpx;
  line-height: 1.7;
}

.field-error {
  margin-top: 10rpx;
  color: #9e3d22;
  font-size: 22rpx;
  line-height: 1.6;
}

.field-tip {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a7768;
}

.create-action-row {
  margin-top: 24rpx;
}
