.store-hero {
  padding: 30rpx;
  background:
    linear-gradient(160deg, rgba(22, 12, 10, 0.06), rgba(22, 12, 10, 0)),
    radial-gradient(circle at top right, rgba(219, 234, 242, 0.22), transparent 34%),
    linear-gradient(135deg, #36495a, #536b82 58%, #88a8be);
  color: #eef7ff;
}

.store-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.78;
}

.store-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
}

.store-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(238, 247, 255, 0.84);
}

.store-card {
  margin-top: 18rpx;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(219, 234, 242, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(241, 248, 252, 0.98), rgba(224, 238, 246, 0.98));
  border: 1rpx solid rgba(87, 119, 145, 0.08);
}

.section-title-inline {
  font-size: 28rpx;
  font-weight: 700;
  color: #3f5f78;
}

.store-summary {
  font-size: 24rpx;
  color: #648096;
}

.store-tip {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #617789;
}

.auth-code-action-row {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.auth-code-action-chip,
.staff-roster-action,
.staff-transfer-btn {
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.auth-code-action-chip,
.staff-transfer-btn {
  background: linear-gradient(135deg, #47657f, #6285a5 58%, #8ab0ce);
  color: #f5fbff;
}

.staff-roster-action {
  background: rgba(71, 101, 127, 0.12);
  color: #47657f;
}

.auth-code-list,
.staff-roster-list,
.staff-transfer-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.auth-code-item,
.staff-roster-item,
.staff-transfer-item {
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(87, 119, 145, 0.08);
}

.auth-code-item-head,
.staff-roster-item,
.staff-transfer-item,
.staff-roster-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.auth-code-item-head-side {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.auth-code-item-code {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #3f5f78;
}

.auth-code-item-role,
.staff-roster-role,
.staff-roster-self {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
}

.auth-code-item-status {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
}

.status-ok {
  background: rgba(76, 122, 82, 0.12);
  color: #4c7a52;
}

.status-pending {
  background: rgba(179, 124, 55, 0.14);
  color: #9a6524;
}

.status-disabled {
  background: rgba(120, 127, 132, 0.14);
  color: #6f7880;
}

.auth-code-item-role,
.staff-roster-role {
  background: rgba(71, 101, 127, 0.1);
  color: #47657f;
}

.staff-roster-self {
  background: rgba(78, 122, 82, 0.12);
  color: #4c7a52;
}

.auth-code-item-meta,
.staff-roster-meta,
.staff-transfer-meta {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #6a7d8f;
}

.staff-roster-main {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.staff-roster-main:active {
  opacity: 0.78;
}

.staff-roster-avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: block;
}

.staff-roster-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #47657f, #8ab0ce);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.staff-roster-copy {
  min-width: 0;
  flex: 1;
}

.staff-roster-name,
.staff-transfer-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #3f5f78;
}

.store-dialog-actions {
  margin-top: 24rpx;
}

.store-dialog-btn {
  min-height: 76rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.store-dialog-btn-secondary {
  background: rgba(71, 101, 127, 0.1);
  color: #47657f;
}

.store-dialog-btn-primary {
  background: linear-gradient(135deg, #47657f, #6285a5 58%, #8ab0ce);
  color: #f5fbff;
}

.store-dialog-single {
  width: auto;
  min-width: 188rpx;
  align-self: center;
  margin-top: 18rpx;
  padding: 14rpx 30rpx;
  font-size: 22rpx;
}

.room-dialog {
  max-height: calc(100vh - 160rpx);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.store-dialog-scroll {
  flex: 1;
  min-height: 0;
}

.player-card-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.player-card-avatar,
.player-card-avatar-image {
  width: 98rpx;
  height: 98rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.player-card-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #47657f, #8ab0ce);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.player-card-avatar-image {
  display: block;
}

.player-card-copy {
  min-width: 0;
  flex: 1;
}

.player-card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #355066;
}

.player-card-title {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5f7b91;
}

.player-card-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64798b;
}

.player-card-section {
  margin-top: 22rpx;
}

.player-card-section-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #3f5f78;
}

.player-card-signature {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #607789;
}

.player-card-stats {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.player-card-stat {
  padding: 16rpx 12rpx;
  border-radius: 18rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(87, 119, 145, 0.08);
}

.player-card-stat-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #3f5f78;
}

.player-card-stat-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #708395;
}

.player-card-tag-list {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.player-card-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(71, 101, 127, 0.1);
  color: #47657f;
  font-size: 20rpx;
  font-weight: 700;
}
