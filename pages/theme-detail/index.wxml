<view class="screen">
<view wx:if="{{errorText}}" class="card status-card">
  <view class="status-title">主题加载失败</view>
  <view class="status-text">{{errorText}}</view>
  <view class="button-primary status-action" bindtap="retryLoad">重新加载</view>
</view>

<view wx:elif="{{theme}}">
  <view class="hero-banner">
    <image class="banner-image" src="{{theme.coverImage}}" mode="aspectFill"></image>
    <view class="banner-overlay"></view>
    <view class="banner-kicker">主题详情</view>
    <view class="banner-stamp">沉浸式档案</view>
    <view class="banner-title">{{theme.name}}</view>
    <view class="banner-subtitle">{{theme.slogan}}</view>
    <view wx:if="{{theme.horror || theme.people || theme.duration}}" class="banner-tags">
      <view wx:if="{{theme.horror}}" class="banner-tag">{{theme.horror}}</view>
      <view wx:if="{{theme.people}}" class="banner-tag">{{theme.people}}</view>
      <view wx:if="{{theme.duration}}" class="banner-tag">{{theme.duration}}</view>
    </view>
  </view>

  <view class="panel dossier-panel">
    <view class="dossier-head">
      <view class="dossier-title">主题信息</view>
      <view class="dossier-note">{{theme.horror}} · {{theme.difficulty}}</view>
    </view>
    <view class="dossier-code">主题编号 {{theme.id}}</view>
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">难度</text>
        <text class="info-value">{{theme.difficulty}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">恐怖度</text>
        <text class="info-value">{{theme.horror}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">恐怖星级</text>
        <view class="info-value theme-star-line">
          <text class="detail-star-active">{{theme.horrorStarsFilledText}}</text>
          <text class="detail-star-inactive">{{theme.horrorStarsEmptyText}}</text>
        </view>
      </view>
      <view class="info-item">
        <text class="info-label">人数</text>
        <text class="info-value">{{theme.people}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">时长</text>
        <text class="info-value">{{theme.duration}}</text>
      </view>
    </view>
    <view class="tag-wrap">
      <text class="tag" wx:for="{{theme.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="panel narrative-panel detail-accordion-panel">
    <view class="detail-accordion-head" data-key="story" bindtap="toggleDetailSection">
      <view>
        <view class="content-kicker">剧情介绍</view>
        <view class="content-title">故事背景</view>
      </view>
      <view class="detail-accordion-toggle">{{activeDetailSection === 'story' ? '收起' : '展开'}}</view>
    </view>
    <view wx:if="{{activeDetailSection === 'story'}}" class="detail-accordion-body">
      <view class="content-text">{{theme.story}}</view>
    </view>
  </view>

  <view class="panel guide-panel detail-accordion-panel">
    <view class="detail-accordion-head" data-key="guide" bindtap="toggleDetailSection">
      <view>
        <view class="content-kicker">游玩建议</view>
        <view class="content-title">适合什么样的玩家</view>
      </view>
      <view class="detail-accordion-toggle">{{activeDetailSection === 'guide' ? '收起' : '展开'}}</view>
    </view>
    <view wx:if="{{activeDetailSection === 'guide'}}" class="detail-accordion-body">
      <view class="guide-line" wx:for="{{theme.highlights}}" wx:key="*this">
        <view class="guide-dot"></view>
        <view class="guide-text">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="panel review-panel detail-accordion-panel">
    <view class="detail-accordion-head" data-key="reviews" bindtap="toggleDetailSection">
      <view>
        <view class="content-kicker">现场反馈</view>
        <view class="content-title">玩家评价 {{reviewStats.totalCount}}</view>
      </view>
      <view class="detail-accordion-toggle">{{activeDetailSection === 'reviews' ? '收起' : '展开'}}</view>
    </view>
    <view wx:if="{{activeDetailSection === 'reviews'}}" class="detail-accordion-body">
      <view class="review-summary-card">
        <view class="review-summary-item">
          <view class="review-summary-value">{{reviewStats.totalCount}}</view>
          <view class="review-summary-label">评价数</view>
        </view>
        <view class="review-summary-item">
          <view class="review-summary-value">{{reviewStats.avgScore}}</view>
          <view class="review-summary-label">综合评分</view>
        </view>
        <view class="review-summary-item">
          <view class="review-summary-value">{{reviewStats.positiveRate}}%</view>
          <view class="review-summary-label">推荐率</view>
        </view>
      </view>

      <view class="review-highlight-box">
        <view class="review-highlight-head" bindtap="toggleReviewHighlights">
          <view>
            <view class="review-subtitle">精选评价</view>
            <view class="review-subdesc">先看看大家最常提到的真实感受。</view>
          </view>
          <view class="detail-accordion-toggle">{{reviewHighlightsExpanded ? '收起' : '展开'}}</view>
        </view>
        <view wx:if="{{reviewHighlightsExpanded}}" class="review-highlight-list">
          <view wx:if="{{theme.reviewHighlights.length}}">
            <view class="review-highlight-item" wx:for="{{theme.reviewHighlights}}" wx:for-item="highlight" wx:key="reviewId">
              <view class="review-highlight-meta">
                <text class="review-highlight-name">{{highlight.authorNicknameSnapshot || '匿名玩家'}}</text>
                <text>{{highlight.authorRoleLabel}}</text>
                <text>{{highlight.rating}} 分</text>
              </view>
              <view class="review-highlight-content">{{highlight.content}}</view>
            </view>
          </view>
          <view wx:else class="empty-text review-empty-text">还没有精选评价。</view>
        </view>
      </view>

      <view class="review-page-entry-row">
        <view class="button-primary review-page-entry-btn" bindtap="openThemeReviews">查看全部评价</view>
      </view>
    </view>
  </view>

  <view class="action-row">
    <view class="button-primary" bindtap="goGroup">发起队伍</view>
  </view>
</view>

<view wx:else class="card status-card">
  <view class="status-title">暂时无法查看主题</view>
  <view class="status-text">这个主题暂时无法查看，请稍后再试。</view>
</view>

<view wx:if="{{dialogVisible}}" class="detail-mask modal-mask-center" bindtap="closeDialog">
  <view class="detail-dialog modal-card-common" catchtap="noop">
    <view class="detail-dialog-title modal-title-common">{{dialogTitle}}</view>
    <view class="detail-dialog-content modal-content-common">{{dialogContent}}</view>
    <view class="button-primary detail-dialog-btn" bindtap="closeDialog">关闭</view>
  </view>
</view>
</view>
